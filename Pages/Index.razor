@* ─────────────────────────────────────────────────────────────────────────────
   Index.razor — Page principale du calendrier de l'application Obrigenie.

   Il s'agit de la route d'accueil ("/") et de la vue principale avec laquelle
   les utilisateurs authentifiés et licenciés interagissent. Elle prend en charge
   cinq modes d'affichage contrôlés par une barre d'outils :
     • SingleDay   — grille horaire pour un jour (06:00–22:00)
     • Week        — grille Lun–Ven pour la semaine en cours
     • WeekAndWeekend — grille Lun–Dim pour la semaine en cours
     • Month       — grille complète sur 6 semaines du mois
     • SchoolPeriod — vue "trimestre" : toutes les semaines d'une période scolaire
                      en colonnes, Lun–Ven en lignes (tableau défilant horizontalement)

   Fonctionnalités supplémentaires :
     • Flèches de navigation pour avancer/reculer par jour, semaine ou période
     • Bandeau d'étiquette de période scolaire (ex. "Toussaint → Noël") au-dessus de la grille
     • Cliquer sur une cellule de jour en vue semaine/mois bascule vers la vue jour unique
     • Cliquer sur un créneau horaire en vue jour unique ouvre la fenêtre modale de note
     • Fenêtre modale de note : créer, modifier ou supprimer des notes horodatées
   ───────────────────────────────────────────────────────────────────────────── *@

@* Route : la page d'accueil de l'application *@
@page "/"

@* Injection de AuthService pour vérifier si l'utilisateur est authentifié au chargement *@
@inject AuthService Auth

@* Injection de NavigationManager pour rediriger vers /login si non authentifié *@
@inject NavigationManager Nav

@* Injection de ApiService pour les appels HTTP des cours et des notes *@
@inject ApiService Api

@* Injection de CalendarService pour charger les données de vacances de l'année scolaire *@
@inject CalendarService CalendarSvc

@* ── Barre d'outils du mode d'affichage ──────────────────────────────────── *@
<div class="calendar-container">
    <div class="view-mode-bar">
        @* Chaque bouton reçoit la classe CSS "active" quand son mode correspond au viewMode actuel *@
        <button class="@(viewMode == CalendarViewMode.SingleDay      ? "view-btn active" : "view-btn")"
                @onclick='() => SetViewMode(CalendarViewMode.SingleDay)'>Day</button>
        <button class="@(viewMode == CalendarViewMode.Week           ? "view-btn active" : "view-btn")"
                @onclick='() => SetViewMode(CalendarViewMode.Week)'>Week</button>
        <button class="@(viewMode == CalendarViewMode.WeekAndWeekend ? "view-btn active" : "view-btn")"
                @onclick='() => SetViewMode(CalendarViewMode.WeekAndWeekend)'>Week+</button>
        <button class="@(viewMode == CalendarViewMode.Month          ? "view-btn active" : "view-btn")"
                @onclick='() => SetViewMode(CalendarViewMode.Month)'>Month</button>
        <button class="@(viewMode == CalendarViewMode.SchoolPeriod   ? "view-btn active" : "view-btn")"
                @onclick='() => SetViewMode(CalendarViewMode.SchoolPeriod)'>Period</button>
    </div>

    @* ── En-tête de navigation ─────────────────────────────────────────────── *@
    @* Contient les flèches précédent/suivant, le titre de la période et (en mode
       SchoolPeriod) la plage de dates exacte affichée sous le titre. *@
    <div class="calendar-header">
        @* Bouton précédent : recule d'un jour, d'une semaine, d'un mois ou d'une période scolaire *@
        <button class="nav-btn" @onclick="MovePrevious">&lt;</button>
        <div class="week-title-group">
            @* Texte du titre principal (ex. "Semaine 01/09 – 05/09" ou "Octobre 2025") *@
            <h2 class="week-title">@weekTitle</h2>
            @* En mode SchoolPeriod, affiche aussi les dates exactes de début et de fin de la période *@
            @if (viewMode == CalendarViewMode.SchoolPeriod && schoolPeriodStart != DateTime.MinValue)
            {
                <span class="period-dates-sub">
                    @schoolPeriodStart.ToString("dd/MM/yyyy") → @schoolPeriodEnd.ToString("dd/MM/yyyy")
                </span>
            }
        </div>
        @* Bouton suivant : avance d'un jour, d'une semaine, d'un mois ou d'une période scolaire *@
        <button class="nav-btn" @onclick="MoveNext">&gt;</button>
    </div>

    @* ── Bandeau d'étiquette de période scolaire ───────────────────────────── *@
    @* Affiché dans tous les modes sauf SchoolPeriod lui-même.
       Indique la position actuelle dans l'année scolaire (ex. "Toussaint → Noël").
       Les périodes de vacances affichent "Congé de Toussaint" avec un modificateur CSS distinct. *@
    @if (!string.IsNullOrEmpty(periodLabel))
    {
        <div class="period-label @(periodLabel.StartsWith("Congé") ? "period-label--holiday" : "")">
            📚 @periodLabel
        </div>
    }

    @* ════════════════════════════════════════════════════════════════════════
       VUE : JOUR UNIQUE — grille horaire
       ════════════════════════════════════════════════════════════════════════ *@
    @if (viewMode == CalendarViewMode.SingleDay && currentDay != null)
    {
        @* En-tête du jour : nom complet du jour de la semaine et numéro du jour *@
        <div class="single-day-header">
            <span class="day-name">@currentDay.DayOfWeek</span>
            <span class="day-number">@currentDay.DayOfMonth</span>
        </div>

        @* Grille horaire de 06:00 à 22:00 *@
        <div class="time-grid">
            @for (int h = 6; h <= 22; h++)
            {
                @* Capture la variable de boucle pour que la fermeture lambda capture la bonne valeur *@
                var hour = h;

                @* Recherche un cours dont la plage horaire couvre ce créneau *@
                var course = currentDay.Courses.FirstOrDefault(c =>
                    c.StartTime.Hours <= hour && c.EndTime.Hours > hour);

                @* Recherche une note qui commence exactement à cette heure (affichée uniquement sur sa ligne de départ) *@
                var noteHere = currentDay.Notes.FirstOrDefault(n => n.Hour == hour);

                @* Recherche une note dont la plage couvre cette heure mais qui a commencé plus tôt
                   (utilisée pour ajouter une classe CSS bloquant le clic de création) *@
                var noteCovering = currentDay.Notes.FirstOrDefault(n =>
                    n.Hour < hour && (n.EndHour > 0 ? n.EndHour : n.Hour + 1) > hour);

                @* Chaque ligne horaire couvre une heure ; cliquer dessus ouvre la modale de note pour cette heure.
                   Si une note couvre déjà cette ligne (noteCovering), on ajoute la classe "time-row-covered"
                   pour indiquer que le clic modifiera la note existante plutôt qu'en créer une nouvelle. *@
                <div class="time-row @(noteCovering != null ? "time-row-covered" : "")"
                     @onclick="() => OnTimeSlotClicked(hour)">

                    @* Côté gauche : l'étiquette de l'heure (ex. "08:00") *@
                    <div class="time-label">@($"{hour:D2}:00")</div>

                    @* Côté droit : bloc de cours et/ou bloc de note pour cette heure *@
                    <div class="time-content">
                        @* Affiche le bloc de cours si un cours couvre cette heure *@
                        @if (course != null)
                        {
                            <div class="course-block" style="background-color: @course.Color;">
                                <span class="course-name">@course.Name</span>
                                @* Affiche les heures de début et de fin exactes du cours *@
                                <span class="course-time">@($"{course.StartTime:hh\\:mm} - {course.EndTime:hh\\:mm}")</span>
                            </div>
                        }

                        @* Affiche le bloc de note uniquement sur la ligne de l'heure de début.
                           Les notes qui s'étendent sur plusieurs heures sont visuellement ancrées ici. *@
                        @if (noteHere != null)
                        {
                            @* Calcule l'heure de fin ; revient à hour+1 quand EndHour vaut 0 *@
                            var endH = noteHere.EndHour > 0 ? noteHere.EndHour : noteHere.Hour + 1;

                            @* stopPropagation empêche le onclick de la ligne de se déclencher à nouveau
                               quand l'utilisateur clique directement sur le bloc de note *@
                            <div class="note-block"
                                 @onclick:stopPropagation="true"
                                 @onclick="() => OnTimeSlotClicked(hour)">
                                @* Affiche la plage horaire de la note *@
                                <span class="note-time">@($"{noteHere.Hour:D2}:00 → {endH:D2}:00")</span>
                                @* Contenu textuel de la note *@
                                @noteHere.Content
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    @* ════════════════════════════════════════════════════════════════════════
       VUE : PÉRIODE SCOLAIRE (TRIMESTRE) — semaines en colonnes, jours en lignes
       ════════════════════════════════════════════════════════════════════════ *@
    else if (viewMode == CalendarViewMode.SchoolPeriod)
    {
        @* État de chargement affiché pendant les appels API en parallèle *@
        @if (trimLoading)
        {
            <div class="trim-loading">Chargement de la période...</div>
        }
        else
        {
            @* Conteneur défilant horizontalement pour que le tableau puisse dépasser la largeur de la fenêtre *@
            <div class="trimestre-scroll">
                <div class="trimestre-table">

                    @* Colonne fixe de gauche : étiquettes des noms de jours (Lun, Mar, Mer, Jeu, Ven) *@
                    <div class="trim-col trim-col-fixed">
                        @* Cellule d'angle vide alignée avec la ligne d'en-tête des semaines *@
                        <div class="trim-cell trim-cell-header trim-corner"></div>
                        <div class="trim-cell trim-cell-day">Mon</div>
                        <div class="trim-cell trim-cell-day">Tue</div>
                        <div class="trim-cell trim-cell-day">Wed</div>
                        <div class="trim-cell trim-cell-day">Thu</div>
                        <div class="trim-cell trim-cell-day">Fri</div>
                    </div>

                    @* Une colonne par semaine scolaire dans la période *@
                    @foreach (var week in trimWeeks)
                    {
                        @* Les semaines entièrement en vacances reçoivent une classe CSS distincte *@
                        <div class="trim-col @(week.IsFullHoliday ? "trim-col-holiday" : "")">

                            @* En-tête de semaine : numéro de semaine scolaire (ex. "S12") et plage de dates *@
                            <div class="trim-cell trim-cell-header">
                                <span class="trim-week-num">@(week.WeekNum.HasValue ? $"S{week.WeekNum}" : "")</span>
                                <span class="trim-week-date">@week.DateLabel</span>
                            </div>

                            @if (week.IsFullHoliday)
                            {
                                @* Quand toute la semaine est en vacances, fusionner les 5 cellules de jours
                                   en un seul bloc de vacances qui s'étend sur toute la colonne *@
                                <div class="trim-cell-holiday-span">@week.HolidayShortName</div>
                            }
                            else
                            {
                                @* Affiche les cellules de jours individuelles pour les semaines sans vacances complètes *@
                                @foreach (var day in week.Days)
                                {
                                    @* Applique les classes CSS pour les jours de vacances, aujourd'hui et les jours hors période *@
                                    <div class="trim-cell @(day.IsInPeriod && day.IsHoliday ? "trim-cell-hol" : "") @(day.IsToday ? "trim-cell-today" : "") @(!day.IsInPeriod ? "trim-cell-out" : "")"
                                         @onclick="() => SelectDay(day.Date)">

                                        @* Affiche le contenu uniquement pour les jours situés dans la période en cours *@
                                        @if (day.IsInPeriod)
                                        {
                                            @* Affiche un badge "C" pour les jours de congé dans la période *@
                                            @if (day.IsHoliday)
                                            {
                                                <span class="trim-conge">C</span>
                                            }

                                            @* Affiche une mini-puce de cours pour chaque cours planifié ce jour *@
                                            @foreach (var c in day.Courses)
                                            {
                                                <div class="trim-course" style="background-color: @c.Color;" title="@c.Name">@c.Name</div>
                                            }

                                            @* Affiche un indicateur de note quand le jour contient au moins une note *@
                                            @if (day.Notes.Any())
                                            {
                                                <div class="trim-note-dot" title="@(day.Notes.Count) note(s)">📝</div>
                                            }
                                        }
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
    @* ════════════════════════════════════════════════════════════════════════
       VUE : SEMAINE / SEMAINE+WEEK-END / MOIS — grille de jours
       ════════════════════════════════════════════════════════════════════════ *@
    else
    {
        @* Ligne d'en-tête des colonnes de la grille : noms de jours abrégés pour chaque colonne *@
        <div class="grid-header" style="grid-template-columns: repeat(@gridSpan, 1fr); display: grid;">
            @foreach (var day in days.Take(gridSpan))
            {
                @* Prend uniquement les 3 premiers caractères du nom du jour (ex. "Lun", "Mar") *@
                <div class="grid-header-cell">@day.DayOfWeek[..3]</div>
            }
        </div>

        @* Grille des cellules de jours — une cellule par jour dans la vue actuelle *@
        <div class="days-grid" style="grid-template-columns: repeat(@gridSpan, 1fr);">
            @foreach (var day in days)
            {
                @* Applique les classes CSS : vacances, rentrée scolaire et mise en évidence d'aujourd'hui *@
                <div class="day-cell @(day.IsHoliday ? "holiday" : "") @(day.IsSchoolStart ? "school-start" : "") @(day.Date == DateTime.Today ? "today" : "")"
                     @onclick="() => SelectDay(day.Date)">

                    @* Numéro du jour dans le coin supérieur gauche de la cellule *@
                    <span class="day-num">@day.DayOfMonth</span>

                    @* Étiquette courte du nom de vacances quand le jour est férié *@
                    @if (!string.IsNullOrEmpty(day.ShortHolidayName))
                    {
                        <span class="holiday-name">@day.ShortHolidayName</span>
                    }

                    @* Affiche jusqu'à 3 mini-puces de cours pour éviter le débordement de la cellule *@
                    @foreach (var course in day.Courses.Take(3))
                    {
                        <div class="course-mini" style="background-color: @course.Color;">@course.Name</div>
                    }

                    @* Affiche jusqu'à 2 aperçus de notes tronqués à 16 caractères *@
                    @foreach (var note in day.Notes.Take(2))
                    {
                        @* Tronque les notes longues et ajoute des points de suspension pour la lisibilité *@
                        var preview = note.Content.Length > 16 ? note.Content[..16] + "…" : note.Content;
                        <div class="note-mini">📝 @preview</div>
                    }
                </div>
            }
        </div>
    }
</div>

@* ════════════════════════════════════════════════════════════════════════════
   MODALE DE NOTE — créer / modifier / supprimer une note horodatée
   ════════════════════════════════════════════════════════════════════════════ *@
@* L'overlay et la carte de la modale ne sont affichés que lorsque showNoteModal est vrai *@
@if (showNoteModal)
{
    @* Overlay semi-transparent : cliquer en dehors de la carte de modale la ferme *@
    <div class="modal-overlay" @onclick="CloseNoteModal">

        @* Carte de la modale : stopPropagation empêche un clic à l'intérieur de la carte
           de remonter jusqu'au gestionnaire de fermeture de l'overlay *@
        <div class="modal-content" @onclick:stopPropagation="true">

            @* Le titre change selon que l'on crée ou modifie une note *@
            <h3>@(editingNote != null ? "Modifier la note" : "Nouvelle note")</h3>

            @* Affiche la date au format français complet pour le contexte *@
            <p class="modal-date">@currentDate.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</p>

            @* Sélecteurs de plage horaire : de 06:00 à 22:00 (début), 07:00 à 23:00 (fin) *@
            <div class="modal-time-range">
                <label>De</label>
                <select @bind="noteStartHour">
                    @for (int h = 6; h <= 22; h++)
                    {
                        <option value="@h">@($"{h:D2}:00")</option>
                    }
                </select>
                <label>à</label>
                <select @bind="noteEndHour">
                    @for (int h = 7; h <= 23; h++)
                    {
                        <option value="@h">@($"{h:D2}:00")</option>
                    }
                </select>
            </div>

            @* Zone de texte de la note : 2000 caractères maximum, un placeholder guide l'utilisateur *@
            <textarea @bind="noteContent" placeholder="Saisissez votre note ici..." rows="4" maxlength="2000"></textarea>

            @* Affichage du nombre de caractères pour que l'utilisateur sache l'espace restant *@
            <div class="modal-char-count">@noteContent.Length / 2000</div>

            <div class="modal-buttons">
                @* Bouton Enregistrer : désactivé quand l'heure de fin n'est pas après l'heure de début *@
                <button class="btn-save" @onclick="SaveNote" disabled="@(noteEndHour <= noteStartHour)">Enregistrer</button>

                @* Bouton Supprimer : affiché uniquement lors de la modification d'une note existante *@
                @if (editingNote != null)
                {
                    <button class="btn-delete" @onclick="DeleteNote">Supprimer</button>
                }

                @* Bouton Annuler : ferme la modale sans enregistrer *@
                <button class="btn-cancel" @onclick="CloseNoteModal">Annuler</button>
            </div>

            @* Erreur de validation : l'heure de fin doit être strictement après l'heure de début *@
            @if (noteEndHour <= noteStartHour)
            {
                <p class="modal-error">L'heure de fin doit être postérieure à l'heure de début.</p>
            }

            @* Erreur API/enregistrement affichée quand le serveur rejette la note *@
            @if (noteSaveError != null)
            {
                <p class="modal-error">@noteSaveError</p>
            }
        </div>
    </div>
}

@code {
    @* ── État de la vue ──────────────────────────────────────────────────────── *@

    @* Le mode d'affichage actif (Semaine par défaut) *@
    private CalendarViewMode viewMode = CalendarViewMode.Week;

    @* Le mode d'affichage actif avant de basculer vers SingleDay via un clic sur une cellule.
       Restauré quand l'utilisateur revient de la vue jour unique vers une vue multi-jours. *@
    private CalendarViewMode previousViewMode = CalendarViewMode.Week;

    @* La date de référence utilisée par tous les calculs de vue (aujourd'hui par défaut) *@
    private DateTime currentDate = DateTime.Today;

    @* La chaîne de titre principal affichée dans l'en-tête de navigation (ex. "Semaine 01/09 – 05/09") *@
    private string weekTitle = "Chargement...";

    @* La liste des modèles Day actuellement affichés dans les vues semaine/mois/grille *@
    private List<Day> days = new();

    @* Le modèle Day unique utilisé dans la vue SingleDay (contient les cours et notes de ce jour) *@
    private Day? currentDay;

    @* Toutes les périodes de vacances chargées depuis CalendarService ; utilisées pour les calculs de période scolaire *@
    private List<Holiday> cachedHolidays = new();

    @* L'étiquette affichée dans le bandeau de période (ex. "Toussaint → Noël"). Null masque le bandeau. *@
    private string? periodLabel;

    @* Date de début de la période scolaire en cours (utilisée dans l'en-tête de la vue SchoolPeriod) *@
    private DateTime schoolPeriodStart;

    @* Date de fin de la période scolaire en cours *@
    private DateTime schoolPeriodEnd;

    @* Vrai pendant le chargement en parallèle des données de la période scolaire depuis l'API *@
    private bool trimLoading = false;

    @* La liste des objets TrimWeek qui alimentent la vue SchoolPeriod (trimestre) *@
    private List<TrimWeek> trimWeeks = new();

    @* Propriété calculée : le nombre de colonnes dans l'en-tête de la grille.
       Semaine = 5 colonnes, WeekAndWeekend/Mois = 7, SingleDay = 1 (inutilisé dans cette vue). *@
    private int gridSpan => viewMode == CalendarViewMode.Week ? 5 :
        viewMode == CalendarViewMode.SingleDay ? 1 : 7;

    @* ── État de la modale de note ──────────────────────────────────────────── *@

    @* Contrôle si l'overlay de la modale de création/modification de note est affiché *@
    private bool showNoteModal = false;

    @* Le contenu textuel de la note en cours de création ou de modification *@
    private string noteContent = "";

    @* La note en cours de modification, ou null lors de la création d'une nouvelle note *@
    private Note? editingNote = null;

    @* L'heure de début sélectionnée dans la liste déroulante "De" de la modale *@
    private int noteStartHour = 8;

    @* L'heure de fin sélectionnée dans la liste déroulante "à" de la modale *@
    private int noteEndHour = 9;

    @* Message d'erreur de l'API si l'enregistrement de la note échoue ; null quand aucune erreur *@
    private string? noteSaveError = null;

    @* ══════════════════════════════════════════════════════════════════════════
       NUMÉROTATION DES SEMAINES SCOLAIRES
       Calcule le numéro de semaine scolaire (S1 = semaine du 1er septembre) pour une
       date de lundi donnée. Retourne null pour juillet et août (grandes vacances), sauf pour
       le lundi de la semaine qui contient le 1er septembre (qui est S1 même quand
       ce lundi tombe fin août, ex. 31 août quand le 1er sept. est un mardi).
       Le compteur repart à S1 au début de chaque nouvelle année scolaire.
       ══════════════════════════════════════════════════════════════════════════ *@

    // Retourne le numéro de semaine scolaire pour le lundi donné, ou null quand la semaine
    // tombe entièrement pendant les grandes vacances (juillet ou août) et n'est pas la semaine S1.
    private static int? GetSchoolWeekNumber(DateTime weekMonday)
    {
        int startYear;

        if (weekMonday.Month >= 9)
        {
            // À partir de septembre : l'année scolaire a commencé cette année civile
            startYear = weekMonday.Year;
        }
        else if (weekMonday.Month <= 6)
        {
            // De janvier à juin : l'année scolaire a commencé l'année civile précédente
            startYear = weekMonday.Year - 1;
        }
        else
        {
            // Juillet ou août : normalement null, mais vérification du cas spécial S1.
            // Si le 1er septembre de cette année tombe en milieu de semaine, le lundi de cette même
            // semaine peut être en août (ex. 1er sept. est mardi → lundi = 31 août = S1).
            var sept1Check = new DateTime(weekMonday.Year, 9, 1);

            // Calcule combien de jours en arrière depuis le 1er sept. pour atteindre le lundi
            int d = ((int)sept1Check.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7;

            if (weekMonday.Date == sept1Check.AddDays(-d).Date)
                startYear = weekMonday.Year;  // C'est la semaine S1 malgré le fait d'être en août
            else
                return null;  // Semaine d'été ordinaire — pas de numéro de semaine scolaire
        }

        // L'ancre pour la semaine S1 est le lundi de la semaine qui contient le 1er septembre
        var sept1 = new DateTime(startYear, 9, 1);
        int daysToMonday = ((int)sept1.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7;
        var rentreeMonday = sept1.AddDays(-daysToMonday);

        // Numéro de semaine = nombre de semaines entières depuis le lundi S1 + 1
        int weekNum = (int)((weekMonday.Date - rentreeMonday.Date).TotalDays / 7) + 1;

        // Retourne null si le numéro est négatif (ne devrait pas arriver en utilisation normale)
        return weekNum >= 1 ? weekNum : null;
    }

    @* ══════════════════════════════════════════════════════════════════════════
       CLASSES DE DONNÉES INTERNES POUR LA VUE PÉRIODE SCOLAIRE (TRIMESTRE)
       ══════════════════════════════════════════════════════════════════════════ *@

    @* Représente une colonne de semaine calendaire dans la vue SchoolPeriod *@
    private class TrimWeek
    {
        @* La date du lundi qui commence cette semaine *@
        public DateTime WeekStart { get; set; }

        @* Le numéro de semaine scolaire (S1, S2, …) ou null pour les semaines d'été *@
        public int? WeekNum { get; set; }

        @* Chaîne de plage de dates formatée pour l'en-tête de colonne (ex. "01/09 – 05/09") *@
        public string DateLabel { get; set; } = "";

        @* Les cinq objets TrimDay du lundi au vendredi de cette semaine *@
        public List<TrimDay> Days { get; set; } = new();

        @* Vrai quand les 5 jours de la semaine sont tous des jours de vacances.
           Utilisé pour réduire toute la colonne de semaine en un seul bloc de vacances. *@
        public bool IsFullHoliday => Days.Count == 5 && Days.All(d => d.IsHoliday);

        @* Le nom court des vacances à afficher quand IsFullHoliday est vrai (ex. "Toussaint") *@
        public string HolidayShortName => Days.FirstOrDefault(d => d.IsHoliday)?.HolidayShortName ?? "Vacances";
    }

    @* Représente une cellule de jour de semaine au sein d'une colonne TrimWeek *@
    private class TrimDay
    {
        @* La date calendaire de ce jour *@
        public DateTime Date { get; set; }

        @* Les cours planifiés pour ce jour *@
        public List<Course> Courses { get; set; } = new();

        @* Les notes écrites pour ce jour *@
        public List<Note> Notes { get; set; } = new();

        @* Vrai quand ce jour tombe dans une période de vacances *@
        public bool IsHoliday { get; set; }

        @* Nom court des vacances couvrant ce jour (ex. "Toussaint") *@
        public string HolidayShortName { get; set; } = "";

        @* Vrai quand ce jour est compris dans la plage de dates de la période scolaire en cours *@
        public bool IsInPeriod { get; set; }

        @* Calculé : vrai quand ce jour est aujourd'hui (comparaison sans la composante heure) *@
        public bool IsToday => Date.Date == DateTime.Today;
    }

    @* ══════════════════════════════════════════════════════════════════════════
       CYCLE DE VIE
       ══════════════════════════════════════════════════════════════════════════ *@

    // Appelée une fois lors du premier rendu de la page.
    // Redirige vers /login si l'utilisateur n'est pas authentifié.
    // Sinon, charge les données de vacances depuis CalendarService (pour les calculs de période)
    // puis affiche la vue calendrier initiale.
    protected override async Task OnInitializedAsync()
    {
        // Garde : les utilisateurs non authentifiés doivent d'abord se connecter
        var isLoggedIn = await Auth.IsLoggedInAsync();
        if (!isLoggedIn) { Nav.NavigateTo("/login"); return; }

        try
        {
            // Charge les données de vacances (API → cache localStorage → fallback hors ligne)
            var calendarData = await CalendarSvc.GetCalendarData();
            cachedHolidays = calendarData.Holidays;
        }
        catch
        {
            // En cas d'échec, cachedHolidays reste vide ; le calendrier s'affiche sans les informations de vacances
        }

        // Affiche la vue semaine par défaut pour aujourd'hui
        await UpdateCalendarView();
    }

    @* ══════════════════════════════════════════════════════════════════════════
       DISPATCH DE LA VUE
       ══════════════════════════════════════════════════════════════════════════ *@

    // Dispatch vers la méthode de mise à jour appropriée selon le viewMode actuel,
    // puis calcule l'étiquette de période pour le bandeau de navigation.
    // Appelée à chaque changement de viewMode ou de currentDate.
    private async Task UpdateCalendarView()
    {
        if      (viewMode == CalendarViewMode.SingleDay)     await UpdateSingleDayView();
        else if (viewMode == CalendarViewMode.Month)         await UpdateMonthView();
        else if (viewMode == CalendarViewMode.SchoolPeriod)  await UpdateSchoolPeriodView();
        else                                                  await UpdateWeekView();

        // L'étiquette de période n'est pas affichée en mode SchoolPeriod (il possède déjà son propre en-tête)
        periodLabel = viewMode == CalendarViewMode.SchoolPeriod
            ? null
            : SchoolPeriodHelper.GetLabel(currentDate, cachedHolidays);
    }

    @* ══════════════════════════════════════════════════════════════════════════
       CONSTRUCTEURS DE VUES
       ══════════════════════════════════════════════════════════════════════════ *@

    // Prépare les données pour la vue SingleDay.
    // Définit le titre avec la chaîne de date complète et charge les cours et notes du jour actuel.
    private async Task UpdateSingleDayView()
    {
        // Format : "lundi 01 septembre 2025" (locale française)
        weekTitle = currentDate.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"));

        // Charge le jour avec ses cours et notes via une séquence API unique
        currentDay = await CreateDayWithDataAsync(currentDate);

        // Synchronise la liste days pour que la vue grille s'affiche correctement si le mode est basculé
        days = new List<Day> { currentDay };
    }

    // Prépare les données pour les vues Semaine (Lun–Ven) et WeekAndWeekend (Lun–Dim).
    // Calcule le lundi de la semaine en cours, construit les modèles de jours pour la plage,
    // puis charge toutes les notes de la plage en une seule requête groupée.
    // Les cours sont chargés par jour uniquement quand l'utilisateur bascule vers la vue jour unique.
    private async Task UpdateWeekView()
    {
        // Trouve le lundi de la semaine contenant currentDate
        int delta = System.DayOfWeek.Monday - currentDate.DayOfWeek;
        if (delta > 0) delta -= 7;  // si aujourd'hui est avant lundi (ex. dimanche), recule
        DateTime monday = currentDate.AddDays(delta);
        DateTime sunday = monday.AddDays(6);

        weekTitle = $"Semaine {monday:dd/MM} – {sunday:dd/MM}";

        // 5 jours en mode Semaine, 7 en mode WeekAndWeekend
        int daysToShow = viewMode == CalendarViewMode.Week ? 5 : 7;
        days = new List<Day>();
        for (int i = 0; i < daysToShow; i++)
            days.Add(CreateDayModel(monday.AddDays(i)));

        // Charge les notes pour tous les jours affichés en une seule requête (plus efficace qu'une par jour)
        var allNotes = await Api.GetNotesForRangeAsync(monday, monday.AddDays(daysToShow - 1));

        // Distribue les notes à leurs modèles de jours respectifs
        foreach (var day in days)
            day.Notes = allNotes.Where(n => n.Date.Date == day.Date.Date).ToList();
    }

    // Prépare les données pour la vue Mois.
    // Construit une grille de 6 semaines (42 jours) à partir du lundi de la semaine qui contient
    // le premier jour du mois, puis charge les notes pour toute la plage visible.
    private async Task UpdateMonthView()
    {
        // Format du titre : "OCTOBRE 2025"
        weekTitle = currentDate.ToString("MMMM yyyy", new System.Globalization.CultureInfo("fr-FR")).ToUpper();

        // Calcule le premier jour du mois affiché
        DateTime first = new DateTime(currentDate.Year, currentDate.Month, 1);

        // Nombre de jours à ajouter en début de grille pour que la grille commence un lundi
        int offset = ((int)first.DayOfWeek - (int)System.DayOfWeek.Monday + 7) % 7;
        DateTime start = first.AddDays(-offset);

        // Construit 42 modèles de jours (6 semaines × 7 jours)
        days = new List<Day>();
        for (int i = 0; i < 42; i++)
            days.Add(CreateDayModel(start.AddDays(i)));

        // Charge les notes en lot pour toute la plage visible de 42 jours
        var allNotes = await Api.GetNotesForRangeAsync(start, start.AddDays(41));
        foreach (var day in days)
            day.Notes = allNotes.Where(n => n.Date.Date == day.Date.Date).ToList();
    }

    // Prépare les données pour la vue SchoolPeriod (trimestre).
    // Calcule les dates de début et de fin de la période scolaire contenant currentDate,
    // puis charge en parallèle les cours et les notes de tous les jours de semaine de la période.
    // Définit trimLoading = true pour afficher un indicateur pendant le chargement.
    private async Task UpdateSchoolPeriodView()
    {
        // Affiche immédiatement l'indicateur de chargement pour que l'interface ne soit pas vide pendant le travail asynchrone
        trimLoading = true;
        StateHasChanged();

        // Calcule les bornes (date de début, date de fin et titre) de la période en cours
        var (start, end, title) = SchoolPeriodHelper.GetPeriodBounds(currentDate, cachedHolidays);
        schoolPeriodStart = start;
        schoolPeriodEnd   = end;
        weekTitle         = title;

        // Trouve le lundi de la semaine qui contient la date de début de la période
        int off = ((int)start.DayOfWeek - (int)System.DayOfWeek.Monday + 7) % 7;
        DateTime gridStart = start.AddDays(-off);

        // Collecte tous les jours de semaine (Lun–Ven) de la période pour les requêtes API groupées
        var weekdays = new List<DateTime>();
        for (DateTime d = gridStart; d.Date <= end.Date; d = d.AddDays(1))
            if (d.DayOfWeek != System.DayOfWeek.Saturday && d.DayOfWeek != System.DayOfWeek.Sunday)
                weekdays.Add(d);

        // Lance une tâche de récupération de cours par jour de semaine et une requête de notes — toutes en parallèle
        var courseTasks = weekdays.Select(d => Api.GetCoursesForDateAsync(d)).ToArray();
        var notesTask   = Api.GetNotesForRangeAsync(gridStart, end);
        await Task.WhenAll(Task.WhenAll(courseTasks), notesTask);

        // Indexe les cours par date pour des recherches en O(1) lors de la construction des objets TrimDay
        var coursesByDate = weekdays
            .Zip(courseTasks.Select(t => t.Result))
            .ToDictionary(p => p.First.Date, p => p.Second);

        // Groupe les notes par date pour des recherches en O(1)
        var allTrimNotes = notesTask.Result;
        var notesByDate = allTrimNotes
            .GroupBy(n => n.Date.Date)
            .ToDictionary(g => g.Key, g => g.ToList());

        trimWeeks = new List<TrimWeek>();

        // Itère une semaine à la fois de gridStart jusqu'à la fin de la période
        for (DateTime ws = gridStart; ws.Date <= end.Date; ws = ws.AddDays(7))
        {
            var week = new TrimWeek
            {
                WeekStart = ws,
                WeekNum   = GetSchoolWeekNumber(ws),
                DateLabel = $"{ws:dd/MM} – {ws.AddDays(6):dd/MM}"
            };

            // Construit cinq objets TrimDay pour Lun–Ven de cette semaine
            for (int d = 0; d < 5; d++)
            {
                DateTime date = ws.AddDays(d);

                // Une entrée "Rentrée" est prioritaire : un jour marqué comme rentrée scolaire ne doit pas
                // aussi être marqué comme vacances même si une période de vacances se chevauche.
                bool isRentreeDay = cachedHolidays.Any(h =>
                    date.Date >= h.StartDate.Date && date.Date <= h.EndDate.Date &&
                    (h.Name.Contains("Rentree") || h.Name.Contains("Rentrée")));

                // Trouve les vacances couvrant ce jour, en ignorant les jours de Rentrée
                var hol = isRentreeDay ? null : cachedHolidays.FirstOrDefault(h =>
                    date.Date >= h.StartDate.Date && date.Date <= h.EndDate.Date &&
                    !h.Name.Contains("Rentree") && !h.Name.Contains("Rentrée"));

                week.Days.Add(new TrimDay
                {
                    Date             = date,
                    Courses          = coursesByDate.GetValueOrDefault(date.Date, new()),
                    Notes            = notesByDate.GetValueOrDefault(date.Date, new()),
                    IsHoliday        = hol != null,
                    HolidayShortName = hol != null ? GetShortHolName(hol.Name) : "",
                    // IsInPeriod indique si ce jour est compris dans la plage de la période scolaire
                    IsInPeriod       = date.Date >= start.Date && date.Date <= end.Date
                });
            }

            trimWeeks.Add(week);
        }

        trimLoading = false;
    }

    // Traduit un nom de vacances complet en une chaîne d'affichage courte pour les cellules TrimDay.
    // Reproduit le mapping utilisé par SchoolPeriodHelper mais est conservé ici car
    // TrimDay est une classe interne privée qui n'a pas accès à l'assistant statique.
    private static string GetShortHolName(string name)
    {
        if (name.Contains("Toussaint") || name.Contains("automne")) return "Toussaint";
        if (name.Contains("Noel") || name.Contains("Noël") || name.Contains("hiver")) return "Noël";
        if (name.Contains("Carnaval") || name.Contains("detente"))   return "Carnaval";
        if (name.Contains("Paques")   || name.Contains("Pâques"))    return "Pâques";
        if (name.Contains("ete")      || name.Contains("été"))        return "Été";
        return "Vacances";
    }

    @* ══════════════════════════════════════════════════════════════════════════
       MÉTHODES AUXILIAIRES
       ══════════════════════════════════════════════════════════════════════════ *@

    // Crée un modèle Day pour la date donnée en résolvant les vacances qui la couvrent.
    // Une vacation "Rentrée" est prioritaire : si le même jour est couvert à la fois par une
    // Rentrée et une vacation ordinaire, il est traité comme un jour de rentrée (pas de vacances).
    private Day CreateDayModel(DateTime date)
    {
        // Vérifie si une entrée "Rentrée" couvre cette date
        var rentree = cachedHolidays.FirstOrDefault(h =>
            date >= h.StartDate && date <= h.EndDate &&
            (h.Name.Contains("Rentree") || h.Name.Contains("Rentre")));

        // Trouve les vacances couvrant cette date, en ignorant les entrées de Rentrée
        var holiday = rentree ?? cachedHolidays.FirstOrDefault(h =>
            date >= h.StartDate && date <= h.EndDate &&
            !h.Name.Contains("Rentree") && !h.Name.Contains("Rentre"));

        bool isRentree = rentree != null;

        return new Day
        {
            Date         = date,
            DayOfWeek    = date.ToString("dddd", new System.Globalization.CultureInfo("fr-FR")),
            DayOfMonth   = date.Day.ToString(),
            // Un jour est marqué comme vacances uniquement si des vacances le couvrent ET ce n'est pas un jour de Rentrée
            IsHoliday    = holiday != null && !isRentree,
            // IsSchoolStart marque le jour de Rentrée avec le marqueur CSS distinctif
            IsSchoolStart = isRentree,
            HolidayName  = holiday?.Name ?? string.Empty,
        };
    }

    // Crée un modèle Day et le peuple avec les cours et les notes pour cette date
    // en effectuant deux appels API asynchrones.
    // Utilisé dans la vue jour unique et après les sauvegardes/suppressions de notes quand le jour doit être actualisé.
    private async Task<Day> CreateDayWithDataAsync(DateTime date)
    {
        var day = CreateDayModel(date);
        // Charge les cours pour cette date spécifique
        day.Courses = await Api.GetCoursesForDateAsync(date);
        // Charge les notes pour cette date spécifique
        day.Notes   = await Api.GetNotesForDateAsync(date);
        return day;
    }

    @* ══════════════════════════════════════════════════════════════════════════
       GESTIONNAIRES DE NAVIGATION
       ══════════════════════════════════════════════════════════════════════════ *@

    // Recule le calendrier d'une unité (jour, semaine ou mois) selon le viewMode.
    // En mode SchoolPeriod, saute à la période scolaire précédente en trouvant les vacances
    // qui se terminent juste avant le début de la période actuelle, puis recule d'un jour.
    private async Task MovePrevious()
    {
        if (viewMode == CalendarViewMode.SingleDay)
        {
            // Recule exactement d'un jour calendaire
            currentDate = currentDate.AddDays(-1);
        }
        else if (viewMode == CalendarViewMode.Month)
        {
            // Recule d'un mois calendaire
            currentDate = currentDate.AddMonths(-1);
        }
        else if (viewMode == CalendarViewMode.SchoolPeriod)
        {
            // Trouve les vacances qui se sont terminées le plus récemment avant la date de début de la période actuelle.
            // On ignore les entrées de Rentrée pour ne naviguer qu'entre de vraies périodes de vacances.
            var prevHol = cachedHolidays
                .Where(h => h.EndDate.Date < schoolPeriodStart.Date &&
                            !h.Name.Contains("Rentree") && !h.Name.Contains("Rentrée"))
                .OrderByDescending(h => h.EndDate)
                .FirstOrDefault();

            // Se place un jour avant le début de ces vacances pour atterrir dans la période précédente
            currentDate = prevHol != null
                ? prevHol.StartDate.AddDays(-1)
                : schoolPeriodStart.AddDays(-30);  // repli : recule de 30 jours
        }
        else
        {
            // Semaine et WeekAndWeekend : recule de 7 jours
            currentDate = currentDate.AddDays(-7);
        }

        await UpdateCalendarView();
    }

    // Avance le calendrier d'une unité (jour, semaine ou mois) selon le viewMode.
    // En mode SchoolPeriod, saute à la période scolaire suivante en trouvant les vacances qui
    // commencent juste après la fin de la période actuelle, puis avance d'un jour.
    private async Task MoveNext()
    {
        if (viewMode == CalendarViewMode.SingleDay)
        {
            currentDate = currentDate.AddDays(1);
        }
        else if (viewMode == CalendarViewMode.Month)
        {
            currentDate = currentDate.AddMonths(1);
        }
        else if (viewMode == CalendarViewMode.SchoolPeriod)
        {
            // Trouve les vacances qui commencent immédiatement après la fin de la période actuelle.
            var nextHol = cachedHolidays
                .Where(h => h.StartDate.Date > schoolPeriodEnd.Date &&
                            !h.Name.Contains("Rentree") && !h.Name.Contains("Rentrée"))
                .OrderBy(h => h.StartDate)
                .FirstOrDefault();

            // Se place un jour après la fin de ces vacances pour atterrir dans la période suivante
            currentDate = nextHol != null
                ? nextHol.EndDate.AddDays(1)
                : schoolPeriodEnd.AddDays(10);  // repli : avance de 10 jours
        }
        else
        {
            currentDate = currentDate.AddDays(7);
        }

        await UpdateCalendarView();
    }

    // Bascule vers le mode d'affichage spécifié et actualise la vue calendrier.
    // Sauvegarde le mode précédent (si pas déjà en SingleDay) pour pouvoir le
    // restaurer quand l'utilisateur revient de la vue jour unique.
    private async Task SetViewMode(CalendarViewMode mode)
    {
        // Enregistre le mode actuel comme "précédent" avant de quitter une vue multi-jours
        if (viewMode != CalendarViewMode.SingleDay)
            previousViewMode = viewMode;

        viewMode = mode;
        await UpdateCalendarView();
    }

    // Bascule vers la vue SingleDay pour la date spécifiée.
    // Appelée quand l'utilisateur clique sur une cellule de jour en vue semaine, mois ou période scolaire.
    // Sauvegarde le mode multi-jours en cours pour pouvoir le restaurer ultérieurement.
    private async Task SelectDay(DateTime date)
    {
        // Préserve le mode actuel avant de basculer vers le jour unique
        if (viewMode != CalendarViewMode.SingleDay)
            previousViewMode = viewMode;

        viewMode = CalendarViewMode.SingleDay;
        currentDate = date;
        await UpdateCalendarView();
    }

    // Fait défiler les modes d'affichage dans un ordre fixe ou retourne au mode précédent
    // lorsqu'on est actuellement en vue SingleDay.
    // Utilisé par un geste de bascule ; non câblé directement à un bouton dans l'interface actuelle
    // mais disponible pour des raccourcis clavier ou des gestes de balayage.
    private async Task ToggleViewMode()
    {
        viewMode = viewMode switch
        {
            CalendarViewMode.SingleDay      => previousViewMode,          // retour au mode multi-jours précédent
            CalendarViewMode.Week           => CalendarViewMode.WeekAndWeekend,
            CalendarViewMode.WeekAndWeekend => CalendarViewMode.Month,
            CalendarViewMode.Month          => CalendarViewMode.Week,
            _                               => CalendarViewMode.Week
        };

        await UpdateCalendarView();
    }

    @* ══════════════════════════════════════════════════════════════════════════
       GESTIONNAIRES DE NOTES
       ══════════════════════════════════════════════════════════════════════════ *@

    // Appelée quand l'utilisateur clique sur un créneau horaire dans la grille du jour unique.
    // Si une note couvre déjà l'heure cliquée, ouvre la modale en mode modification.
    // Sinon, ouvre la modale en mode création avec l'heure cliquée pré-remplie.
    private void OnTimeSlotClicked(int hour)
    {
        // Trouve la note dont la plage horaire inclut l'heure cliquée (peut être null si aucune note n'existe)
        editingNote = currentDay?.Notes.FirstOrDefault(n =>
            hour >= n.Hour && hour < (n.EndHour > 0 ? n.EndHour : n.Hour + 1));

        // Pré-remplit les champs de la modale depuis la note existante (mode modif) ou les valeurs par défaut (mode création)
        noteContent   = editingNote?.Content ?? "";
        noteStartHour = editingNote?.Hour ?? hour;
        noteEndHour   = editingNote?.EndHour > 0 ? editingNote.EndHour : hour + 1;

        // Efface toute erreur d'enregistrement précédente à l'ouverture d'une nouvelle modale
        noteSaveError = null;

        showNoteModal = true;
    }

    // Enregistre la note en cours via l'API.
    // Construit une date UTC à minuit pour éviter les problèmes de décalage horaire lors de la sérialisation JSON
    // (ex. une date sérialisée à +01:00 apparaîtrait comme le jour précédent en UTC).
    // Actualise la vue jour unique après un enregistrement réussi.
    private async Task SaveNote()
    {
        // Ne fait rien si le contexte de jour est absent ou si la plage horaire est invalide
        if (currentDay == null || noteEndHour <= noteStartHour) return;

        noteSaveError = null;

        // Construit un DateTime UTC à minuit pour éviter la dérive horaire dans le corps JSON.
        // L'utilisation de DateTimeKind.Utc garantit que le sérialiseur n'ajoute pas de décalage +HH:mm.
        var noteDate = new DateTime(
            currentDay.Date.Year, currentDay.Date.Month, currentDay.Date.Day,
            0, 0, 0, DateTimeKind.Utc);

        // Réutilise l'objet note existant en modification ; en crée un nouveau en ajout
        var note = editingNote ?? new Note { Date = noteDate };
        note.Hour    = noteStartHour;
        note.EndHour = noteEndHour;
        note.Content = noteContent;

        // Soumet la note à l'API et vérifie les erreurs
        var (success, error) = await Api.SaveNoteAsync(note);
        if (!success) { noteSaveError = error; return; }

        // Ferme la modale et recharge les données du jour pour refléter la note enregistrée
        showNoteModal = false;
        currentDay = await CreateDayWithDataAsync(currentDate);
        days = new List<Day> { currentDay };
    }

    // Supprime la note en cours de modification via l'API.
    // Actualise la vue jour unique après une suppression réussie.
    // Ne fait rien quand aucune note n'est en cours de modification (editingNote est null).
    private async Task DeleteNote()
    {
        // Garde : suppression possible uniquement quand une note existante est en cours de modification
        if (editingNote == null) return;

        await Api.DeleteNoteAsync(editingNote.Id);

        // Ferme la modale et recharge le jour pour supprimer la note de la vue
        showNoteModal = false;
        currentDay = await CreateDayWithDataAsync(currentDate);
        days = new List<Day> { currentDay };
    }

    // Ferme la modale de note sans enregistrer les modifications.
    private void CloseNoteModal() => showNoteModal = false;
}

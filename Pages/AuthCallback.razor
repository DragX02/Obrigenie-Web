@page "/auth-callback"
@inject ApiService Api
@inject AuthService Auth
@inject NavigationManager Nav

<div class="login-container">
    <p>Connexion en cours...</p>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var error = query["error"];

        if (!string.IsNullOrEmpty(error))
        {
            Nav.NavigateTo($"/login?error={error}");
            return;
        }

        // Echanger le cookie temporaire HttpOnly contre les données d'auth
        // (le token ne passe plus jamais dans l'URL)
        var result = await Api.ExchangeOAuthTokenAsync();
        if (result != null)
        {
            await Auth.SaveTokenAsync(result.Token);
            if (!string.IsNullOrEmpty(result.Email))
                await Auth.SaveEmailAsync(result.Email);
            Nav.NavigateTo("/", forceLoad: true);
        }
        else
        {
            Nav.NavigateTo("/login");
        }
    }
}

@* ─────────────────────────────────────────────────────────────────────────────
   TestPage.razor — Page de test de sélection en cascade réservée aux admins.

   Flux de sélection en cascade à 7 niveaux :
     1. Catégorie
     2. Cours
     3. Niveau
     4. Domaine
     5. Sous-domaine (optionnel)
     6. Visée (filtrée par domaine + sous-domaine)
     7. Visée à maîtriser (filtrée par visée)

   Une sous-sélection de langue optionnelle apparaît lorsque le cours "LM" est choisi.
   L'accès est réservé aux utilisateurs ADMIN.
   ───────────────────────────────────────────────────────────────────────────── *@

@page "/test"
@inject AuthService Auth
@inject NavigationManager Nav
@inject ApiService Api

<PageTitle>Cascade Test</PageTitle>

@if (!isAdmin)
{
    <div style="padding:2rem;text-align:center;color:var(--text-muted)">Access denied.</div>
}

@if (loadError != null)
{
    <div class="alert alert-danger m-3">
        <strong>API error:</strong> @loadError
        <br/>
        <small>
            Token present: @(tokenDebug != null ? $"yes ({tokenDebug})" : "NO — not logged in?")
        </small>
    </div>
}
else
{
    <div class="container mt-4">
        <h2>🧪 Cascading Selection Test</h2>
        <hr />

        <div class="row">
            @* ── Colonne gauche : listes déroulantes en cascade ── *@
            <div class="col-md-6">

                @* Étape 1 : catégorie *@
                <div class="mb-3">
                    <label class="form-label fw-bold">1. Choose a Category:</label>
                    <select class="form-select" value="@selectedIdCat" @onchange="OnCategorieChanged">
                        <option value="0">-- Select a category --</option>
                        @foreach (var cat in listeCategories)
                        {
                            <option value="@cat.IdCat">@cat.NomCat</option>
                        }
                    </select>
                </div>

                @* Étape 2 : cours *@
                @if (selectedIdCat > 0)
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">2. Choose a Course:</label>
                        <select class="form-select" value="@selectedCours" @onchange="OnCoursChanged">
                            <option value="">-- Select a course --</option>
                            @foreach (var cours in listeCours)
                            {
                                <option value="@cours.CodeCours">@cours.NomCours</option>
                            }
                        </select>
                    </div>
                }

                @* Étape 3 : niveau *@
                @if (!string.IsNullOrEmpty(selectedCours))
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">3. Choose a Level:</label>
                        <select class="form-select" value="@selectedNiveau" @onchange="OnNiveauChanged">
                            <option value="">-- Select a level --</option>
                            @foreach (var niveau in listeNiveaux)
                            {
                                <option value="@niveau.CodeNiveau">@niveau.NomNiveau</option>
                            }
                        </select>
                    </div>
                }

                @* Sous-sélection langue (LM uniquement) *@
                @if (selectedCours == "LM")
                {
                    <div class="mb-3 p-3 bg-light border rounded">
                        <label class="form-label fw-bold text-primary">⭐ Choose the specific language:</label>
                        <select class="form-select border-primary" value="@selectedLangue" @onchange="OnLangueChanged">
                            <option value="">-- Which language? --</option>
                            <option value="English">English</option>
                            <option value="Dutch">Dutch</option>
                            <option value="German">German</option>
                        </select>
                    </div>
                }

                @* Étape 4 : domaine *@
                @if (!string.IsNullOrEmpty(selectedCours) && !string.IsNullOrEmpty(selectedNiveau))
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">4. Choose a Domain:</label>
                        <select class="form-select" value="@selectedIdDomaine" @onchange="OnDomaineChanged">
                            <option value="0">-- Select a domain --</option>
                            @foreach (var d in domainesFiltres)
                            {
                                <option value="@d.IdDom">@d.Nom</option>
                            }
                        </select>
                    </div>
                }

                @* Étape 5 : sous-domaine (optionnel) *@
                @if (selectedIdDomaine > 0)
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">5. Sous-domaine <span class="text-muted">(optionnel)</span></label>
                        <select class="form-select" value="@selectedIdSousD" @onchange="OnSousDChanged">
                            <option value="0">-- Aucun --</option>
                            @foreach (var s in listeSousDomaines)
                            {
                                <option value="@s.IdSousDomaine">@s.NomComp</option>
                            }
                        </select>
                    </div>
                }

                @* Étape 6 : visée *@
                @if (selectedIdDomaine > 0)
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">6. Visée</label>
                        <select class="form-select" value="@selectedIdVisee" @onchange="OnViseeChanged">
                            <option value="0">-- Select a visée --</option>
                            @foreach (var v in listeVisees)
                            {
                                <option value="@v.IdVisee">@v.Label</option>
                            }
                        </select>
                    </div>
                }

                @* Étape 7 : visée à maîtriser *@
                @if (selectedIdVisee > 0)
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">7. Visée à maîtriser</label>
                        <select class="form-select" value="@selectedIdVm" @onchange="e => selectedIdVm = int.TryParse(e.Value?.ToString(), out var v) ? v : 0">
                            <option value="0">-- Select --</option>
                            @foreach (var vm in listeViseesMaitriser)
                            {
                                <option value="@vm.IdViseesMaitriser">@vm.NomViseesMaitriser</option>
                            }
                        </select>
                    </div>
                }

            </div>

            @* ── Colonne droite : récapitulatif ── *@
            <div class="col-md-6">
                <div class="card bg-dark text-light mt-4">
                    <div class="card-body">
                        <h5 class="card-title">Your selection summary:</h5>
                        <ul>
                            <li><strong>Category:</strong> @(selectedIdCat == 0 ? "..." : (listeCategories.FirstOrDefault(c => c.IdCat == selectedIdCat)?.NomCat ?? "..."))</li>
                            <li><strong>Course:</strong>   @(string.IsNullOrEmpty(selectedCours)   ? "..." : selectedCours)</li>
                            <li><strong>Level:</strong>    @(string.IsNullOrEmpty(selectedNiveau)  ? "..." : selectedNiveau)</li>
                            @if (selectedCours == "LM")
                            {
                                <li class="text-warning"><strong>Language:</strong> @(string.IsNullOrEmpty(selectedLangue) ? "..." : selectedLangue)</li>
                            }
                            <li><strong>Domain:</strong>   @(selectedIdDomaine == 0 ? "..." : (domainesFiltres.FirstOrDefault(d => d.IdDom == selectedIdDomaine)?.Nom ?? "..."))</li>
                            <li><strong>Sous-dom.:</strong> @(selectedIdSousD == 0 ? "—" : (listeSousDomaines.FirstOrDefault(s => s.IdSousDomaine == selectedIdSousD)?.NomComp ?? "..."))</li>
                            <li><strong>Visée:</strong>    @(selectedIdVisee == 0 ? "..." : (listeVisees.FirstOrDefault(v => v.IdVisee == selectedIdVisee)?.Label ?? "..."))</li>
                            <li><strong>VM:</strong>       @(selectedIdVm == 0 ? "..." : (listeViseesMaitriser.FirstOrDefault(vm => vm.IdViseesMaitriser == selectedIdVm)?.NomViseesMaitriser ?? "..."))</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool    isAdmin    = false;
    private string? loadError;
    private string? tokenDebug;

    protected override async Task OnInitializedAsync()
    {
        if (await Auth.IsTokenExpiredAsync())
        {
            await Auth.RemoveTokenAsync();
            Nav.NavigateTo("/login");
            return;
        }

        var role = await Auth.GetRoleAsync();
        isAdmin = role == "ADMIN";

        if (isAdmin)
        {
            var token = await Auth.GetTokenAsync();
            tokenDebug = string.IsNullOrEmpty(token) ? null : token[..Math.Min(20, token.Length)] + "…";

            try
            {
                listeCategories = await Api.GetCategoriesAsync();
            }
            catch (Exception ex)
            {
                loadError = ex.Message;
            }
        }
    }

    // ── Sélections courantes ───────────────────────────────────────────────
    private int    selectedIdCat      = 0;
    private string selectedCours      = "";
    private string selectedNiveau     = "";
    private string selectedLangue     = "";
    private int    selectedIdDomaine  = 0;
    private int    selectedIdSousD    = 0;  // sous-domaine (0 = aucun)
    private int    selectedIdVisee    = 0;
    private int    selectedIdVm       = 0;  // visée à maîtriser

    // ── Listes chargées depuis l'API ──────────────────────────────────────
    private List<CategorieDto>          listeCategories      = new();
    private List<CoursDto>              listeCours           = new();
    private List<NiveauDto>             listeNiveaux         = new();
    private List<DomaineDto>            domainesFiltres      = new();
    private List<SousDomaineRefDto>     listeSousDomaines    = new();
    private List<ViseeRefDto>           listeVisees          = new();
    private List<ViseesMaitriserRefDto> listeViseesMaitriser = new();

    // ── Gestionnaires ─────────────────────────────────────────────────────

    private async Task OnCategorieChanged(ChangeEventArgs e)
    {
        selectedIdCat = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        ResetFrom(1);
        if (selectedIdCat > 0)
            try { listeCours = await Api.GetCoursAsync(selectedIdCat); }
            catch (Exception ex) { loadError = ex.Message; }
    }

    private async Task OnCoursChanged(ChangeEventArgs e)
    {
        selectedCours = e.Value?.ToString() ?? "";
        ResetFrom(2);
        if (!string.IsNullOrEmpty(selectedCours))
            try { listeNiveaux = await Api.GetNiveauxAsync(selectedCours); }
            catch (Exception ex) { loadError = ex.Message; }
    }

    private async Task OnNiveauChanged(ChangeEventArgs e)
    {
        selectedNiveau = e.Value?.ToString() ?? "";
        ResetFrom(3);
        await ChargerDomaines();
    }

    private void OnLangueChanged(ChangeEventArgs e)
    {
        selectedLangue = e.Value?.ToString() ?? "";
    }

    private async Task OnDomaineChanged(ChangeEventArgs e)
    {
        selectedIdDomaine = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        ResetFrom(4);
        if (selectedIdDomaine > 0)
        {
            try { listeSousDomaines = await Api.GetSousDomainesRefAsync(selectedIdDomaine); }
            catch (Exception ex) { loadError = ex.Message; }
            await ChargerVisees();
        }
    }

    private async Task OnSousDChanged(ChangeEventArgs e)
    {
        selectedIdSousD = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        ResetFrom(5);
        await ChargerVisees();
    }

    private async Task OnViseeChanged(ChangeEventArgs e)
    {
        selectedIdVisee = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        selectedIdVm    = 0;
        listeViseesMaitriser.Clear();
        if (selectedIdVisee > 0)
            try { listeViseesMaitriser = await Api.GetViseesMaitriserRefAsync(selectedIdVisee); }
            catch (Exception ex) { loadError = ex.Message; }
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    // Réinitialise toutes les sélections/listes en aval du niveau indiqué (1=cours, 2=niveaux, …)
    private void ResetFrom(int level)
    {
        if (level <= 1) { selectedCours = ""; listeCours.Clear(); }
        if (level <= 2) { selectedNiveau = ""; listeNiveaux.Clear(); }
        if (level <= 3) { selectedIdDomaine = 0; domainesFiltres.Clear(); selectedLangue = ""; }
        if (level <= 4) { selectedIdSousD = 0; listeSousDomaines.Clear(); selectedIdVisee = 0; listeVisees.Clear(); }
        if (level <= 5) { selectedIdVisee = 0; listeVisees.Clear(); }
        selectedIdVm = 0; listeViseesMaitriser.Clear();
    }

    private async Task ChargerDomaines()
    {
        domainesFiltres.Clear();
        if (string.IsNullOrEmpty(selectedCours) || string.IsNullOrEmpty(selectedNiveau)) return;
        try { domainesFiltres = await Api.GetDomainesAsync(selectedCours, selectedNiveau); }
        catch (Exception ex) { loadError = ex.Message; }
    }

    private async Task ChargerVisees()
    {
        listeVisees.Clear();
        selectedIdVisee = 0; listeViseesMaitriser.Clear();
        if (selectedIdDomaine == 0) return;
        try { listeVisees = await Api.GetViseesRefAsync(selectedIdDomaine, selectedIdSousD > 0 ? selectedIdSousD : null); }
        catch (Exception ex) { loadError = ex.Message; }
    }
}

@* ─────────────────────────────────────────────────────────────────────────────
   TestPage.razor — Page de test de sélection en cascade réservée aux admins.

   Cette page démontre et teste le flux de sélection en cascade à quatre niveaux
   utilisé dans l'API de données de référence :
     1. Catégorie  (catégorie de matière de premier niveau, ex. : "Sciences et techniques")
     2. Cours      (cours au sein de la catégorie sélectionnée)
     3. Niveau     (niveau scolaire, filtré par le cours sélectionné)
     4. Domaine    (domaine pédagogique, filtré par le cours + le niveau sélectionnés)..

   Une sous-sélection de langue optionnelle apparaît lorsque le cours "LM" (Langues Modernes)
   est choisi. Une carte récapitulative affiche les sélections courantes en temps réel.

   L'accès est réservé aux utilisateurs ADMIN — les non-admins voient un message "Accès refusé".
   ───────────────────────────────────────────────────────────────────────────── *@

@* Route : accessible à /test ; affiché dans la navigation flyout admin *@
@page "/test"

@* Injection d'AuthService pour lire le rôle de l'utilisateur depuis le JWT à l'initialisation *@
@inject AuthService Auth

@* Injection d'ApiService pour charger les listes de données de référence depuis l'API *@
@inject ApiService Api

<PageTitle>Cascade Test</PageTitle>

@* ── Garde d'accès ─────────────────────────────────────────────────────────── *@
@if (!isAdmin)
{
    @* Les non-admins voient uniquement ce message ; aucune donnée de référence n'est chargée ni affichée *@
    <div style="padding:2rem;text-align:center;color:var(--text-muted)">Access denied.</div>
}

@* ── Bandeau d'erreur API (affiché uniquement si le chargement des données de référence échoue) ───── *@
@if (loadError != null)
{
    <div class="alert alert-danger m-3">
        <strong>API error:</strong> @loadError
        <br/>
        <small>
            Token present: @(tokenDebug != null ? $"yes ({tokenDebug})" : "NO — not logged in?")
        </small>
    </div>
}
else
{
    <div class="container mt-4">
        <h2>🧪 Cascading Selection Test</h2>
        <hr />

        <div class="row">
            @* ── Colonne gauche : listes déroulantes en cascade ──────────────────────────── *@
            <div class="col-md-6">

                @* ── Étape 1 : sélection de la catégorie ────────────────────────────────────
                   Charge la liste categorie_cours de premier niveau à l'initialisation.
                   Sélectionner une catégorie déclenche le chargement de la liste de cours.
                ── *@
                <div class="mb-3">
                    <label class="form-label fw-bold">1. Choose a Category:</label>
                    <select class="form-select" value="@selectedIdCat" @onchange="OnCategorieChanged">
                        <option value="0">-- Select a category --</option>
                        @foreach (var cat in listeCategories)
                        {
                            <option value="@cat.IdCat">@cat.NomCat</option>
                        }
                    </select>
                </div>

                @* ── Étape 2 : sélection du cours ───────────────────────────────────
                   Affiché uniquement après qu'une catégorie a été sélectionnée.
                   La liste est peuplée par OnCategorieChanged appelant GetCoursAsync(idCat).
                ── *@
                @if (selectedIdCat > 0)
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">2. Choose a Course:</label>
                        <select class="form-select" value="@selectedCours" @onchange="OnCoursChanged">
                            <option value="">-- Select a course --</option>
                            @foreach (var cours in listeCours)
                            {
                                <option value="@cours.CodeCours">@cours.NomCours</option>
                            }
                        </select>
                    </div>
                }

                @* ── Étape 3 : sélection du niveau ────────────────────────────────────
                   Affiché uniquement après qu'un cours a été sélectionné.
                   La liste est peuplée par OnCoursChanged appelant GetNiveauxAsync.
                ── *@
                @if (!string.IsNullOrEmpty(selectedCours))
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">3. Choose a Level:</label>
                        <select class="form-select" value="@selectedNiveau" @onchange="OnNiveauChanged">
                            <option value="">-- Select a level --</option>
                            @foreach (var niveau in listeNiveaux)
                            {
                                <option value="@niveau.CodeNiveau">@niveau.NomNiveau</option>
                            }
                        </select>
                    </div>
                }

                @* ── Sous-sélection de langue (cours LM uniquement) ──────────────────
                   Lorsque l'utilisateur sélectionne le cours "LM" (Langues Modernes),
                   une liste déroulante supplémentaire permet de préciser la langue.
                ── *@
                @if (selectedCours == "LM")
                {
                    <div class="mb-3 p-3 bg-light border rounded">
                        <label class="form-label fw-bold text-primary">⭐ Choose the specific language:</label>
                        <select class="form-select border-primary" value="@selectedLangue" @onchange="OnLangueChanged">
                            <option value="">-- Which language? --</option>
                            <option value="English">English</option>
                            <option value="Dutch">Dutch</option>
                            <option value="German">German</option>
                        </select>
                    </div>
                }

                @* ── Étape 4 : sélection du domaine ───────────────────────────────────
                   Affiché uniquement après qu'un cours et un niveau ont été sélectionnés.
                   La liste est peuplée par MettreAJourDomaines appelant GetDomainesAsync.
                ── *@
                @if (!string.IsNullOrEmpty(selectedCours) && !string.IsNullOrEmpty(selectedNiveau))
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">4. Choose a Domain:</label>
                        <select class="form-select" @bind="selectedDomaine">
                            <option value="">-- Select a domain --</option>
                            @foreach (var domaine in domainesFiltres)
                            {
                                <option value="@domaine.Nom">@domaine.Nom</option>
                            }
                        </select>
                    </div>
                }

            </div>

            @* ── Colonne droite : récapitulatif des sélections en temps réel ─────────────────────── *@
            <div class="col-md-6">
                <div class="card bg-dark text-light mt-4">
                    <div class="card-body">
                        <h5 class="card-title">Your selection summary:</h5>
                        <ul>
                            @* Catégorie : affiche le nom ou un espace réservé *@
                            <li><strong>Category:</strong> @(selectedIdCat == 0 ? "..." : (listeCategories.FirstOrDefault(c => c.IdCat == selectedIdCat)?.NomCat ?? "..."))</li>

                            @* Cours : affiche le code ou un espace réservé *@
                            <li><strong>Course:</strong>  @(string.IsNullOrEmpty(selectedCours)   ? "..." : selectedCours)</li>

                            @* Niveau : affiche le code ou un espace réservé *@
                            <li><strong>Level:</strong>   @(string.IsNullOrEmpty(selectedNiveau)  ? "..." : selectedNiveau)</li>

                            @* Ligne langue : affichée uniquement lorsque le cours LM est sélectionné *@
                            @if (selectedCours == "LM")
                            {
                                <li class="text-warning"><strong>Language:</strong> @(string.IsNullOrEmpty(selectedLangue) ? "..." : selectedLangue)</li>
                            }

                            @* Domaine : affiche le nom ou un espace réservé *@
                            <li><strong>Domain:</strong>  @(string.IsNullOrEmpty(selectedDomaine) ? "..." : selectedDomaine)</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // True lorsque le JWT de l'utilisateur contient le rôle ADMIN
    private bool isAdmin = false;

    // Contient le message d'erreur du dernier appel API échoué ; null si tout va bien
    private string? loadError;

    // Les 20 premiers caractères du jeton JWT stocké, utilisés pour confirmer la présence du jeton dans localStorage
    private string? tokenDebug;

    // Méthode de cycle de vie appelée au premier rendu.
    // Décode le rôle de l'utilisateur ; si ADMIN, charge la liste des catégories depuis l'API.
    // Les non-admins voient le message d'accès refusé et aucune donnée n'est récupérée.
    protected override async Task OnInitializedAsync()
    {
        var role = await Auth.GetRoleAsync();
        isAdmin = role == "ADMIN";

        if (isAdmin)
        {
            var token = await Auth.GetTokenAsync();
            tokenDebug = string.IsNullOrEmpty(token) ? null : token[..Math.Min(20, token.Length)] + "…";

            try
            {
                listeCategories = await Api.GetCategoriesAsync();
            }
            catch (Exception ex)
            {
                loadError = ex.Message;
            }
        }
    }

    // ── Sélections courantes ───────────────────────────────────────────────────

    // L'identifiant de la catégorie actuellement sélectionnée (0 = rien de sélectionné)
    private int selectedIdCat = 0;

    // Le code du cours actuellement sélectionné (ex. : "LM", "SC")
    private string selectedCours   = "";

    // Le code du niveau scolaire actuellement sélectionné
    private string selectedNiveau  = "";

    // Le nom de la langue actuellement sélectionnée (cours LM uniquement)
    private string selectedLangue  = "";

    // Le nom du domaine actuellement sélectionné
    private string selectedDomaine = "";

    // ── Listes de données chargées depuis l'API ──────────────────────────────

    // Catégories de premier niveau ; peuplées à l'initialisation
    private List<CategorieDto> listeCategories = new();

    // Cours pour la catégorie sélectionnée ; peuplés après la sélection de catégorie
    private List<CoursDto>   listeCours      = new();

    // Niveaux pour le cours sélectionné ; peuplés après la sélection de cours
    private List<NiveauDto>  listeNiveaux    = new();

    // Domaines correspondant au cours et au niveau sélectionnés ; peuplés après la sélection de niveau
    private List<DomaineDto> domainesFiltres = new();

    // ── Gestionnaires d'événements ────────────────────────────────────────────

    // Appelé lorsque l'utilisateur change la liste déroulante de catégorie.
    // Réinitialise toutes les sélections en aval et récupère la liste de cours pour la nouvelle catégorie.
    private async Task OnCategorieChanged(ChangeEventArgs e)
    {
        selectedIdCat   = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        selectedCours   = "";
        selectedNiveau  = "";
        selectedLangue  = "";
        selectedDomaine = "";
        listeCours.Clear();
        listeNiveaux.Clear();
        domainesFiltres.Clear();

        if (selectedIdCat > 0)
        {
            try
            {
                listeCours = await Api.GetCoursAsync(selectedIdCat);
            }
            catch (Exception ex)
            {
                loadError = ex.Message;
            }
        }
    }

    // Appelé lorsque l'utilisateur change la liste déroulante de cours.
    // Réinitialise les sélections en aval et récupère la liste de niveaux pour le nouveau cours.
    private async Task OnCoursChanged(ChangeEventArgs e)
    {
        selectedCours   = e.Value?.ToString() ?? "";
        selectedNiveau  = "";
        selectedLangue  = "";
        selectedDomaine = "";
        domainesFiltres.Clear();

        if (!string.IsNullOrEmpty(selectedCours))
        {
            try
            {
                listeNiveaux = await Api.GetNiveauxAsync(selectedCours);
            }
            catch (Exception ex)
            {
                loadError = ex.Message;
            }
        }
    }

    // Appelé lorsque l'utilisateur change la liste déroulante de niveau.
    // Réinitialise la sélection de domaine et déclenche un rafraîchissement de la liste des domaines.
    private async Task OnNiveauChanged(ChangeEventArgs e)
    {
        selectedNiveau  = e.Value?.ToString() ?? "";
        selectedDomaine = "";
        await MettreAJourDomaines();
    }

    // Appelé lorsque l'utilisateur change la liste déroulante de langue (cours LM uniquement).
    private void OnLangueChanged(ChangeEventArgs e)
    {
        selectedLangue  = e.Value?.ToString() ?? "";
        selectedDomaine = "";
    }

    // Récupère la liste des domaines filtrés par le cours et le niveau actuellement sélectionnés.
    private async Task MettreAJourDomaines()
    {
        domainesFiltres.Clear();

        if (string.IsNullOrEmpty(selectedCours) || string.IsNullOrEmpty(selectedNiveau))
            return;

        try
        {
            domainesFiltres = await Api.GetDomainesAsync(selectedCours, selectedNiveau);
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
    }
}

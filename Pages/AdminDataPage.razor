@* Page d'administration des données pédagogiques.
   Accessible uniquement aux administrateurs (vérification via isAdmin dans MainLayout).
   Permet de créer, lister et supprimer les enregistrements des tables de référence :
   catégories, cours, niveaux, liaisons cours-niveau, domaines, compétences, aptitudes,
   noms de visées, visées à maîtriser et sous-domaines. *@

@page "/admin-data"
@inject ApiService Api
@inject NavigationManager Nav
@inject AuthService Auth

<PageTitle>Gestion des données</PageTitle>

@if (!isAdmin)
{
    <div class="alert alert-danger mt-4">Accès réservé aux administrateurs.</div>
}
else if (isLoading)
{
    <div class="text-center mt-5"><span class="spinner-border"></span></div>
}
else
{
    <div class="container-fluid py-3">
        <h2 class="mb-3">Gestion des données pédagogiques</h2>

        @* Barre d'onglets *@
        <ul class="nav nav-tabs flex-wrap mb-3">
            @foreach (var t in tabs)
            {
                <li class="nav-item">
                    <button class="nav-link @(activeTab == t ? "active" : "")"
                            @onclick="() => activeTab = t">@t</button>
                </li>
            }
        </ul>

        @* Message de retour global *@
        @if (!string.IsNullOrEmpty(feedback))
        {
            <div class="alert @(feedbackOk ? "alert-success" : "alert-danger") alert-dismissible">
                @feedback
                <button type="button" class="btn-close" @onclick="() => feedback = null"></button>
            </div>
        }

        @* ── CATÉGORIES ───────────────────────────────────────────── *@
        @if (activeTab == "Catégories")
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">Nouvelle catégorie</div>
                        <div class="card-body">
                            <input class="form-control mb-2" placeholder="Nom" @bind="newCatNom" />
                            <input class="form-control mb-2" type="number" placeholder="Ordre" @bind="newCatOrdre" />
                            <button class="btn btn-primary w-100" @onclick="CreateCategorie">Ajouter</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <table class="table table-sm table-hover">
                        <thead><tr><th>ID</th><th>Nom</th><th>Ordre</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var c in categories)
                            {
                                <tr>
                                    <td>@c.IdCat</td>
                                    <td>@c.NomCat</td>
                                    <td>@c.Ordre</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCategorie(c.IdCat)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── COURS ────────────────────────────────────────────────── *@
        @if (activeTab == "Cours")
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">Nouveau cours</div>
                        <div class="card-body">
                            <input class="form-control mb-2" placeholder="Nom du cours" @bind="newCoursNom" />
                            <input class="form-control mb-2" placeholder="Code (ex: LM)" @bind="newCoursCode" />
                            <input class="form-control mb-2" placeholder="Préfixe" @bind="newCoursPrefix" />
                            <input class="form-control mb-2" type="color" @bind="newCoursCouleur" title="Couleur agenda" />
                            <select class="form-select mb-2" @bind="newCoursIdCat">
                                <option value="0">-- Catégorie --</option>
                                @foreach (var c in categories)
                                {
                                    <option value="@c.IdCat">@c.NomCat</option>
                                }
                            </select>
                            <button class="btn btn-primary w-100" @onclick="CreateCours">Ajouter</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <table class="table table-sm table-hover">
                        <thead><tr><th>ID</th><th>Nom</th><th>Code</th><th>Couleur</th><th>Catégorie</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var c in coursList)
                            {
                                <tr>
                                    <td>@c.IdCours</td>
                                    <td>@c.NomCours</td>
                                    <td><code>@c.CodeCours</code></td>
                                    <td><span style="display:inline-block;width:20px;height:20px;background:@c.CouleurAgenda;border-radius:3px"></span></td>
                                    <td>@(c.NomCat ?? "—")</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCours(c.IdCours)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── NIVEAUX ─────────────────────────────────────────────── *@
        @if (activeTab == "Niveaux")
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">Nouveau niveau</div>
                        <div class="card-body">
                            <input class="form-control mb-2" placeholder="Code (ex: 1A)" @bind="newNivCode" />
                            <input class="form-control mb-2" placeholder="Nom (ex: Première année)" @bind="newNivNom" />
                            <button class="btn btn-primary w-100" @onclick="CreateNiveau">Ajouter</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <table class="table table-sm table-hover">
                        <thead><tr><th>ID</th><th>Code</th><th>Nom</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var n in niveaux)
                            {
                                <tr>
                                    <td>@n.IdNiveau</td>
                                    <td><code>@n.CodeNiveau</code></td>
                                    <td>@n.NomNiveau</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteNiveau(n.IdNiveau)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── LIAISONS COURS-NIVEAU ───────────────────────────────── *@
        @if (activeTab == "Liaisons")
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">Nouvelle liaison</div>
                        <div class="card-body">
                            <select class="form-select mb-2" @bind="newCnIdCours">
                                <option value="0">-- Cours --</option>
                                @foreach (var c in coursList)
                                {
                                    <option value="@c.IdCours">@c.NomCours</option>
                                }
                            </select>
                            <select class="form-select mb-2" @bind="newCnIdNiveau">
                                <option value="0">-- Niveau --</option>
                                @foreach (var n in niveaux)
                                {
                                    <option value="@n.IdNiveau">@n.NomNiveau</option>
                                }
                            </select>
                            <select class="form-select mb-2" @bind="newCnIdProf">
                                <option value="0">-- Professeur --</option>
                                @foreach (var p in professeurs)
                                {
                                    <option value="@p.IdUser">@(p.Prenom + " " + p.Nom) (@p.Email)</option>
                                }
                            </select>
                            <button class="btn btn-primary w-100" @onclick="CreateCoursNiveau">Ajouter</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <table class="table table-sm table-hover">
                        <thead><tr><th>ID</th><th>Cours</th><th>Niveau</th><th>Professeur</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var cn in coursNiveaux)
                            {
                                <tr>
                                    <td>@cn.IdCoursNiveau</td>
                                    <td>@cn.NomCours</td>
                                    <td>@cn.NomNiveau</td>
                                    <td>@(cn.NomProf?.Trim() + " (" + cn.EmailProf + ")")</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCoursNiveau(cn.IdCoursNiveau)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── DOMAINES ────────────────────────────────────────────── *@
        @if (activeTab == "Domaines")
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">Nouveau domaine</div>
                        <div class="card-body">
                            <input class="form-control mb-2" placeholder="Nom du domaine" @bind="newDomNom" />
                            <select class="form-select mb-2" @bind="newDomIdCn">
                                <option value="0">-- Liaison cours-niveau --</option>
                                @foreach (var cn in coursNiveaux)
                                {
                                    <option value="@cn.IdCoursNiveau">@cn.NomCours — @cn.NomNiveau</option>
                                }
                            </select>
                            <button class="btn btn-primary w-100" @onclick="CreateDomaine">Ajouter</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <table class="table table-sm table-hover">
                        <thead><tr><th>ID</th><th>Nom</th><th>Cours</th><th>Niveau</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var d in domaines)
                            {
                                <tr>
                                    <td>@d.IdDom</td>
                                    <td>@d.Nom</td>
                                    <td>@d.NomCours</td>
                                    <td>@d.NomNiveau</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteDomaine(d.IdDom)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── SOUS-DOMAINES ───────────────────────────────────────── *@
        @if (activeTab == "Sous-domaines")
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">Nouveau sous-domaine</div>
                        <div class="card-body">
                            <input class="form-control mb-2" placeholder="Nom" @bind="newSdNom" />
                            <select class="form-select mb-2" @bind="newSdIdDom">
                                <option value="0">-- Domaine --</option>
                                @foreach (var d in domaines)
                                {
                                    <option value="@d.IdDom">@d.Nom (@d.NomCours / @d.NomNiveau)</option>
                                }
                            </select>
                            <button class="btn btn-primary w-100" @onclick="CreateSousDomaine">Ajouter</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <table class="table table-sm table-hover">
                        <thead><tr><th>ID</th><th>Nom</th><th>Domaine</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var s in sousDomaines)
                            {
                                <tr>
                                    <td>@s.IdSousDomaine</td>
                                    <td>@s.NomComp</td>
                                    <td>@s.NomDom</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSousDomaine(s.IdSousDomaine)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── COMPÉTENCES ─────────────────────────────────────────── *@
        @if (activeTab == "Compétences")
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">Nouvelle compétence</div>
                        <div class="card-body">
                            <input class="form-control mb-2" placeholder="Nom de la compétence" @bind="newCompNom" />
                            <button class="btn btn-primary w-100" @onclick="CreateCompetence">Ajouter</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <table class="table table-sm table-hover">
                        <thead><tr><th>ID</th><th>Nom</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var c in competences)
                            {
                                <tr>
                                    <td>@c.IdCompetence</td>
                                    <td>@c.NomCompetence</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCompetence(c.IdCompetence)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── APTITUDES ───────────────────────────────────────────── *@
        @if (activeTab == "Aptitudes")
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">Nouvelle aptitude</div>
                        <div class="card-body">
                            <input class="form-control mb-2" placeholder="Nom de l'aptitude" @bind="newAptNom" />
                            <button class="btn btn-primary w-100" @onclick="CreateAptitude">Ajouter</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <table class="table table-sm table-hover">
                        <thead><tr><th>ID</th><th>Nom</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var a in aptitudes)
                            {
                                <tr>
                                    <td>@a.IdAptitude</td>
                                    <td>@a.NomAptitude</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAptitude(a.IdAptitude)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── NOMS DE VISÉES ──────────────────────────────────────── *@
        @if (activeTab == "Noms visées")
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">Nouveau nom de visée</div>
                        <div class="card-body">
                            <input class="form-control mb-2" placeholder="Intitulé" @bind="newNvNom" />
                            <button class="btn btn-primary w-100" @onclick="CreateNomVisee">Ajouter</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <table class="table table-sm table-hover">
                        <thead><tr><th>ID</th><th>Intitulé</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var n in nomVisees)
                            {
                                <tr>
                                    <td>@n.IdNomVisee</td>
                                    <td>@n.NomVisee1</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteNomVisee(n.IdNomVisee)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── VISÉES À MAÎTRISER ──────────────────────────────────── *@
        @if (activeTab == "Visées à maîtriser")
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">Nouvelle visée à maîtriser</div>
                        <div class="card-body">
                            <textarea class="form-control mb-2" rows="3" placeholder="Description" @bind="newVmNom"></textarea>
                            <button class="btn btn-primary w-100" @onclick="CreateViseesMaitriser">Ajouter</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <table class="table table-sm table-hover">
                        <thead><tr><th>ID</th><th>Description</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var v in viseesMaitriser)
                            {
                                <tr>
                                    <td>@v.IdViseesMaitriser</td>
                                    <td>@v.NomViseesMaitriser</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteViseesMaitriser(v.IdViseesMaitriser)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── VISÉES (objectifs d'apprentissage) avec sélecteurs en cascade ── *@
        @if (activeTab == "Visées")
        {
            <div class="row g-3">
                <div class="col-md-5">
                    <div class="card">
                        <div class="card-header">Nouvelle visée — sélection en cascade</div>
                        <div class="card-body">
                            @* Étape 1 : catégorie → filtre les cours *@
                            <label class="form-label fw-bold">1. Catégorie</label>
                            <select class="form-select mb-2" @onchange="OnViseeCatChanged">
                                <option value="0">-- Catégorie --</option>
                                @foreach (var c in categories)
                                {
                                    <option value="@c.IdCat">@c.NomCat</option>
                                }
                            </select>

                            @* Étape 2 : cours (filtré par catégorie) → filtre les liaisons cours-niveau *@
                            <label class="form-label fw-bold">2. Cours</label>
                            <select class="form-select mb-2" @onchange="OnViseeCourChanged" disabled="@(vCatId == 0)">
                                <option value="0">-- Cours --</option>
                                @foreach (var c in coursList.Where(x => x.IdCatFk == vCatId))
                                {
                                    <option value="@c.IdCours">@c.NomCours</option>
                                }
                            </select>

                            @* Étape 3 : liaison cours-niveau (filtré par cours) → filtre les domaines *@
                            <label class="form-label fw-bold">3. Niveau</label>
                            <select class="form-select mb-2" @onchange="OnViseeCnChanged" disabled="@(vCoursId == 0)">
                                <option value="0">-- Niveau --</option>
                                @foreach (var cn in coursNiveaux.Where(x => x.IdCoursFk == vCoursId))
                                {
                                    <option value="@cn.IdCoursNiveau">@cn.NomNiveau</option>
                                }
                            </select>

                            @* Étape 4 : domaine (filtré par liaison) → filtre les sous-domaines *@
                            <label class="form-label fw-bold">4. Domaine</label>
                            <select class="form-select mb-2" @onchange="OnViseeDomaineChanged" disabled="@(vCnId == 0)">
                                <option value="0">-- Domaine --</option>
                                @foreach (var d in domaines.Where(x => x.IdCoursNiveauFk == vCnId))
                                {
                                    <option value="@d.IdDom">@d.Nom</option>
                                }
                            </select>

                            @* Étape 5 (optionnelle) : sous-domaine *@
                            <label class="form-label fw-bold">5. Sous-domaine <span class="text-muted">(optionnel)</span></label>
                            <select class="form-select mb-2" @bind="vSousDomId" disabled="@(vDomaineId == 0)">
                                <option value="0">-- Aucun --</option>
                                @foreach (var s in sousDomaines.Where(x => x.IdDomFk == vDomaineId))
                                {
                                    <option value="@s.IdSousDomaine">@s.NomComp</option>
                                }
                            </select>

                            @* Étape 6 : nom de visée (type d'objectif) *@
                            <label class="form-label fw-bold">6. Type de visée</label>
                            <select class="form-select mb-2" @bind="vNomViseeId">
                                <option value="0">-- Type --</option>
                                @foreach (var n in nomVisees)
                                {
                                    <option value="@n.IdNomVisee">@n.NomVisee1</option>
                                }
                            </select>

                            @* Étape 7 : compétence liée à la visée *@
                            <label class="form-label fw-bold">7. Compétence</label>
                            <select class="form-select mb-2" @bind="vCompId">
                                <option value="0">-- Compétence --</option>
                                @foreach (var c in competences)
                                {
                                    <option value="@c.IdCompetence">@c.NomCompetence</option>
                                }
                            </select>

                            <hr class="my-2" />

                            @* Étape 8 (optionnelle) : visée à maîtriser → crée le lien automatiquement *@
                            <label class="form-label fw-bold">8. Visée à maîtriser <span class="text-muted">(optionnel)</span></label>
                            <select class="form-select mb-2" @bind="vVmId">
                                <option value="0">-- Aucune --</option>
                                @foreach (var vm in viseesMaitriser)
                                {
                                    <option value="@vm.IdViseesMaitriser">@vm.NomViseesMaitriser</option>
                                }
                            </select>

                            @* Étape 9 (optionnelle) : aptitude → crée l'entrée appartenir si une VM est sélectionnée *@
                            <label class="form-label fw-bold">9. Aptitude <span class="text-muted">(optionnel)</span></label>
                            <select class="form-select mb-3" @bind="vAptId" disabled="@(vVmId == 0)">
                                <option value="0">-- Aucune --</option>
                                @foreach (var a in aptitudes)
                                {
                                    <option value="@a.IdAptitude">@a.NomAptitude</option>
                                }
                            </select>

                            <button class="btn btn-primary w-100" @onclick="CreateVisee"
                                    disabled="@(vDomaineId == 0 || vNomViseeId == 0 || vCompId == 0)">
                                Créer la visée
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-7">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr><th>ID</th><th>Type</th><th>Cours</th><th>Domaine</th><th>S-Dom</th><th>Compétence</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var v in visees)
                            {
                                <tr>
                                    <td>@v.IdVisee</td>
                                    <td>@v.NomViseeType</td>
                                    <td>@v.NomCours / @v.NomNiveau</td>
                                    <td>@v.NomDomaine</td>
                                    <td>@(v.NomSousDomaine ?? "—")</td>
                                    <td>@v.NomCompetence</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteVisee(v.IdVisee)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── LIAISONS VISÉE ↔ VISÉE À MAÎTRISER ─────────────────── *@
        @if (activeTab == "Liens V→M")
        {
            <div class="row g-3">
                <div class="col-md-5">
                    <div class="card">
                        <div class="card-header">Lier une visée à une visée à maîtriser</div>
                        <div class="card-body">
                            <label class="form-label fw-bold">Visée</label>
                            <select class="form-select mb-2" @bind="lienIdVisee">
                                <option value="0">-- Visée --</option>
                                @foreach (var v in visees)
                                {
                                    <option value="@v.IdVisee">[@v.IdVisee] @v.NomViseeType — @v.NomCours / @v.NomDomaine</option>
                                }
                            </select>
                            <label class="form-label fw-bold">Visée à maîtriser</label>
                            <select class="form-select mb-3" @bind="lienIdVm">
                                <option value="0">-- Visée à maîtriser --</option>
                                @foreach (var vm in viseesMaitriser)
                                {
                                    <option value="@vm.IdViseesMaitriser">[@vm.IdViseesMaitriser] @vm.NomViseesMaitriser</option>
                                }
                            </select>
                            <button class="btn btn-primary w-100" @onclick="CreateLienViseeMaitrise"
                                    disabled="@(lienIdVisee == 0 || lienIdVm == 0)">
                                Créer le lien
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-7">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr><th>Visée</th><th>Visée à maîtriser</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var l in liensViseeMaitrise)
                            {
                                <tr>
                                    <td>[@l.IdVisee] @l.ContexteVisee</td>
                                    <td>[@l.IdViseesMaitriser] @l.NomViseesMaitriser</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLienViseeMaitrise(l.IdVisee, l.IdViseesMaitriser)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ── LIAISONS VISÉE_MAITRISER ↔ APTITUDE ↔ COMPÉTENCE ────── *@
        @if (activeTab == "Aptit.→VM")
        {
            <div class="row g-3">
                <div class="col-md-5">
                    <div class="card">
                        <div class="card-header">Lier visée à maîtriser ↔ aptitude ↔ compétence</div>
                        <div class="card-body">
                            <label class="form-label fw-bold">Visée à maîtriser</label>
                            <select class="form-select mb-2" @bind="aptVmId">
                                <option value="0">-- Visée à maîtriser --</option>
                                @foreach (var vm in viseesMaitriser)
                                {
                                    <option value="@vm.IdViseesMaitriser">@vm.NomViseesMaitriser</option>
                                }
                            </select>
                            <label class="form-label fw-bold">Aptitude <span class="text-muted">(optionnel)</span></label>
                            <select class="form-select mb-2" @bind="aptAptId">
                                <option value="0">-- Aucune --</option>
                                @foreach (var a in aptitudes)
                                {
                                    <option value="@a.IdAptitude">@a.NomAptitude</option>
                                }
                            </select>
                            <label class="form-label fw-bold">Compétence</label>
                            <select class="form-select mb-3" @bind="aptCompId">
                                <option value="0">-- Compétence --</option>
                                @foreach (var c in competences)
                                {
                                    <option value="@c.IdCompetence">@c.NomCompetence</option>
                                }
                            </select>
                            <button class="btn btn-primary w-100" @onclick="CreateAppartenir"
                                    disabled="@(aptVmId == 0 || aptCompId == 0)">
                                Créer la liaison
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-7">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr><th>Visée à maîtriser</th><th>Aptitude</th><th>Compétence</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var a in appartenirs)
                            {
                                <tr>
                                    <td>@a.NomVm</td>
                                    <td>@(a.NomAptitude ?? "—")</td>
                                    <td>@a.NomComp</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAppartenir(a.IdAppartenirViseeAptitude)">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

    </div>
}

@code {
    // Indique si la page est encore en train de charger les données initiales
    private bool isLoading = true;

    // Indique si l'utilisateur connecté est administrateur
    private bool isAdmin = false;

    // Onglet actuellement sélectionné
    private string activeTab = "Catégories";

    // Liste des noms d'onglets dans l'ordre d'affichage
    private readonly string[] tabs =
    {
        "Catégories", "Cours", "Niveaux", "Liaisons",
        "Domaines", "Sous-domaines",
        "Compétences", "Aptitudes",
        "Noms visées", "Visées à maîtriser",
        "Visées", "Liens V→M", "Aptit.→VM"
    };

    // Message de retour affiché après une action (succès ou erreur)
    private string? feedback;

    // True si le message de retour représente un succès, false pour une erreur
    private bool feedbackOk;

    // ── Données chargées depuis l'API ─────────────────────────────────────
    private List<CategorieAdminDto>      categories     = new();
    private List<CoursAdminDto>          coursList      = new();
    private List<NiveauAdminDto>         niveaux        = new();
    private List<ProfesseurAdminDto>     professeurs    = new();
    private List<CoursNiveauAdminDto>    coursNiveaux   = new();
    private List<DomaineAdminDto>        domaines       = new();
    private List<SousDomaineAdminDto>    sousDomaines   = new();
    private List<CompetenceAdminDto>     competences    = new();
    private List<AptitudeAdminDto>       aptitudes      = new();
    private List<NomViseeAdminDto>       nomVisees      = new();
    private List<ViseesMaitriserAdminDto> viseesMaitriser = new();
    private List<ViseeAdminDto>          visees          = new();
    private List<LienViseeMaitriseAdminDto> liensViseeMaitrise = new();
    private List<AppartenirAdminDto>     appartenirs     = new();

    // ── Sélecteurs en cascade pour la création d'une visée ───────────────
    private int vCatId      = 0;
    private int vCoursId    = 0;
    private int vCnId       = 0;
    private int vDomaineId  = 0;
    private int vSousDomId  = 0;
    private int vNomViseeId = 0;
    private int vCompId     = 0;
    // Liaisons optionnelles créées en même temps que la visée
    private int vVmId  = 0; // visée à maîtriser (étape 8)
    private int vAptId = 0; // aptitude pour appartenir (étape 9)

    // ── Champs de saisie — Liaison visée ↔ visée à maîtriser ─────────────
    private int lienIdVisee = 0;
    private int lienIdVm    = 0;

    // ── Champs de saisie — Appartenir visée_maitriser ↔ aptitude/compétence
    private int aptVmId   = 0;
    private int aptAptId  = 0;
    private int aptCompId = 0;

    // ── Champs de saisie — Catégorie ─────────────────────────────────────
    private string newCatNom   = "";
    private int    newCatOrdre = 0;

    // ── Champs de saisie — Cours ─────────────────────────────────────────
    private string newCoursNom     = "";
    private string newCoursCode    = "";
    private string newCoursPrefix  = "";
    private string newCoursCouleur = "#3B82F6";
    private int    newCoursIdCat   = 0;

    // ── Champs de saisie — Niveau ────────────────────────────────────────
    private string newNivCode  = "";
    private string newNivNom   = "";
    private int    newNivOrdre = 0;

    // ── Champs de saisie — Cours-Niveau ──────────────────────────────────
    private int newCnIdCours  = 0;
    private int newCnIdNiveau = 0;
    private int newCnIdProf   = 0;

    // ── Champs de saisie — Domaine ────────────────────────────────────────
    private string newDomNom  = "";
    private int    newDomIdCn = 0;

    // ── Champs de saisie — Sous-domaine ──────────────────────────────────
    private string newSdNom   = "";
    private int    newSdIdDom = 0;

    // ── Champs de saisie — Compétence ────────────────────────────────────
    private string newCompNom = "";

    // ── Champs de saisie — Aptitude ──────────────────────────────────────
    private string newAptNom = "";

    // ── Champs de saisie — Nom visée ─────────────────────────────────────
    private string newNvNom = "";

    // ── Champs de saisie — Visée à maîtriser ─────────────────────────────
    private string newVmNom = "";

    // Charge toutes les listes au démarrage de la page après vérification du rôle admin.
    protected override async Task OnInitializedAsync()
    {
        // Redirection si le token est absent ou expiré
        if (await Auth.IsTokenExpiredAsync())
        {
            await Auth.RemoveTokenAsync();
            Nav.NavigateTo("/login");
            return;
        }

        isAdmin = (await Auth.GetRoleAsync()) == "ADMIN";
        if (!isAdmin) { isLoading = false; return; }

        // Chargement en parallèle de tous les jeux de données
        await Task.WhenAll(
            LoadCategories(), LoadCours(), LoadNiveaux(), LoadProfesseurs(),
            LoadCoursNiveaux(), LoadDomaines(), LoadSousDomaines(),
            LoadCompetences(), LoadAptitudes(), LoadNomVisees(), LoadViseesMaitriser(),
            LoadVisees(), LoadLiensViseeMaitrise(), LoadAppartenirs()
        );
        isLoading = false;
    }

    // Affiche un message de retour pendant 3 secondes puis l'efface automatiquement.
    // ok : true pour succès (vert), false pour erreur (rouge)
    // msg : texte du message à afficher
    private async Task ShowFeedback(bool ok, string msg)
    {
        feedbackOk = ok;
        feedback   = msg;
        StateHasChanged();
        await Task.Delay(3000);
        feedback = null;
        StateHasChanged();
    }

    // ── Chargements ──────────────────────────────────────────────────────
    private async Task LoadCategories()    => categories      = await Api.GetAdminCategoriesAsync();
    private async Task LoadCours()         => coursList       = await Api.GetAdminCoursAsync();
    private async Task LoadNiveaux()       => niveaux         = await Api.GetAdminNiveauxAsync();
    private async Task LoadProfesseurs()   => professeurs     = await Api.GetAdminProfesseursAsync();
    private async Task LoadCoursNiveaux()  => coursNiveaux    = await Api.GetAdminCoursNiveauxAsync();
    private async Task LoadDomaines()      => domaines        = await Api.GetAdminDomainesAsync();
    private async Task LoadSousDomaines()  => sousDomaines    = await Api.GetAdminSousDomainesAsync();
    private async Task LoadCompetences()   => competences     = await Api.GetAdminCompetencesAsync();
    private async Task LoadAptitudes()     => aptitudes       = await Api.GetAdminAptitudesAsync();
    private async Task LoadNomVisees()     => nomVisees       = await Api.GetAdminNomViseesAsync();
    private async Task LoadViseesMaitriser() => viseesMaitriser = await Api.GetAdminViseesMaitriserAsync();
    private async Task LoadVisees()           => visees          = await Api.GetAdminViseesAsync();
    private async Task LoadLiensViseeMaitrise() => liensViseeMaitrise = await Api.GetAdminLiensViseeMaitriseAsync();
    private async Task LoadAppartenirs()      => appartenirs     = await Api.GetAdminAppartenirAsync();

    // ── Événements en cascade — Visées ───────────────────────────────────

    // Catégorie sélectionnée → réinitialise tous les sélecteurs en aval
    private void OnViseeCatChanged(ChangeEventArgs e)
    {
        vCatId     = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        vCoursId   = 0; vCnId = 0; vDomaineId = 0; vSousDomId = 0;
    }

    // Cours sélectionné → réinitialise les sélecteurs en aval du cours
    private void OnViseeCourChanged(ChangeEventArgs e)
    {
        vCoursId  = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        vCnId = 0; vDomaineId = 0; vSousDomId = 0;
    }

    // Niveau (liaison cours-niveau) sélectionné → réinitialise domaine et sous-domaine
    private void OnViseeCnChanged(ChangeEventArgs e)
    {
        vCnId      = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        vDomaineId = 0; vSousDomId = 0;
    }

    // Domaine sélectionné → réinitialise le sous-domaine
    private void OnViseeDomaineChanged(ChangeEventArgs e)
    {
        vDomaineId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        vSousDomId = 0;
    }

    // ── Actions — Visées ─────────────────────────────────────────────────

    // Crée une nouvelle visée via la sélection en cascade et recharge la liste.
    // Si une visée à maîtriser (étape 8) est sélectionnée, crée aussi le lien automatiquement.
    // Si une aptitude (étape 9) est sélectionnée en plus, crée aussi l'entrée appartenir.
    private async Task CreateVisee()
    {
        var (ok, err) = await Api.CreateAdminViseeAsync(new
        {
            idCoursNiveauFk = vCnId,
            idDomaineFk     = vDomaineId,
            idSousDomaineFk = vSousDomId == 0 ? (int?)null : vSousDomId,
            idNomViseeFk    = vNomViseeId,
            idCompFk        = vCompId
        });

        if (!ok) { await ShowFeedback(false, err ?? "Erreur"); return; }

        // Récupère l'id de la visée fraîchement créée (dernier élément après rechargement)
        await LoadVisees();
        var newId = visees.Count > 0 ? visees[^1].IdVisee : 0;

        // Crée le lien visée ↔ visée à maîtriser si sélectionnée
        if (vVmId != 0 && newId != 0)
        {
            await Api.CreateAdminLienViseeMaitriseAsync(new { idVisee = newId, idViseesMaitriser = vVmId });
            await LoadLiensViseeMaitrise();

            // Crée l'entrée appartenir si une aptitude est aussi sélectionnée
            if (vAptId != 0)
            {
                await Api.CreateAdminAppartenirAsync(new
                {
                    idViseesMaitriserFk = vVmId,
                    idAptitudeFk        = (int?)vAptId,
                    idCompetenceFk      = vCompId
                });
                await LoadAppartenirs();
            }
        }

        // Sauvegarde avant reset pour le message de confirmation
        bool avecLiaisons = vVmId != 0;

        // Réinitialise tous les sélecteurs
        vCatId = 0; vCoursId = 0; vCnId = 0;
        vDomaineId = 0; vSousDomId = 0; vNomViseeId = 0; vCompId = 0;
        vVmId = 0; vAptId = 0;

        await ShowFeedback(true, avecLiaisons ? "Visée créée + liaisons automatiques." : "Visée créée.");
    }

    // Supprime une visée par son identifiant et recharge la liste
    private async Task DeleteVisee(int id)
    {
        var (ok, err) = await Api.DeleteAdminViseeAsync(id);
        if (ok) await LoadVisees();
        await ShowFeedback(ok, ok ? "Visée supprimée." : err ?? "Erreur");
    }

    // ── Actions — Liaisons visée ↔ visée à maîtriser ─────────────────────

    // Crée un lien many-to-many visée ↔ visée à maîtriser et recharge la liste
    private async Task CreateLienViseeMaitrise()
    {
        var (ok, err) = await Api.CreateAdminLienViseeMaitriseAsync(new { idVisee = lienIdVisee, idViseesMaitriser = lienIdVm });
        if (ok) { lienIdVisee = 0; lienIdVm = 0; await LoadLiensViseeMaitrise(); }
        await ShowFeedback(ok, ok ? "Lien créé." : err ?? "Erreur");
    }

    // Supprime un lien visée ↔ visée à maîtriser et recharge la liste
    private async Task DeleteLienViseeMaitrise(int idVisee, int idVm)
    {
        var (ok, err) = await Api.DeleteAdminLienViseeMaitriseAsync(idVisee, idVm);
        if (ok) await LoadLiensViseeMaitrise();
        await ShowFeedback(ok, ok ? "Lien supprimé." : err ?? "Erreur");
    }

    // ── Actions — Appartenir (visée_maitriser ↔ aptitude ↔ compétence) ───

    // Crée une liaison appartenir et recharge la liste
    private async Task CreateAppartenir()
    {
        var (ok, err) = await Api.CreateAdminAppartenirAsync(new
        {
            idViseesMaitriserFk = aptVmId,
            idAptitudeFk        = aptAptId == 0 ? (int?)null : aptAptId,
            idCompetenceFk      = aptCompId
        });
        if (ok) { aptVmId = 0; aptAptId = 0; aptCompId = 0; await LoadAppartenirs(); }
        await ShowFeedback(ok, ok ? "Liaison créée." : err ?? "Erreur");
    }

    // Supprime une liaison appartenir par son identifiant et recharge la liste
    private async Task DeleteAppartenir(int id)
    {
        var (ok, err) = await Api.DeleteAdminAppartenirAsync(id);
        if (ok) await LoadAppartenirs();
        await ShowFeedback(ok, ok ? "Liaison supprimée." : err ?? "Erreur");
    }

    // ── Actions — Catégories ─────────────────────────────────────────────

    // Crée une nouvelle catégorie et recharge la liste
    private async Task CreateCategorie()
    {
        var (ok, err) = await Api.CreateAdminCategorieAsync(new { nomCat = newCatNom, ordre = newCatOrdre });
        if (ok) { newCatNom = ""; newCatOrdre = 0; await LoadCategories(); }
        await ShowFeedback(ok, ok ? "Catégorie ajoutée." : err ?? "Erreur");
    }

    // Supprime une catégorie par son identifiant et recharge la liste
    private async Task DeleteCategorie(int id)
    {
        var (ok, err) = await Api.DeleteAdminCategorieAsync(id);
        if (ok) await LoadCategories();
        await ShowFeedback(ok, ok ? "Catégorie supprimée." : err ?? "Erreur");
    }

    // ── Actions — Cours ──────────────────────────────────────────────────

    // Crée un nouveau cours et recharge la liste
    private async Task CreateCours()
    {
        var (ok, err) = await Api.CreateAdminCoursAsync(new
        {
            nomCours = newCoursNom, codeCours = newCoursCode,
            prefixCours = newCoursPrefix, couleurAgenda = newCoursCouleur,
            idCatFk = newCoursIdCat == 0 ? (int?)null : newCoursIdCat
        });
        if (ok) { newCoursNom = ""; newCoursCode = ""; newCoursPrefix = ""; await LoadCours(); }
        await ShowFeedback(ok, ok ? "Cours ajouté." : err ?? "Erreur");
    }

    // Supprime un cours par son identifiant et recharge la liste
    private async Task DeleteCours(int id)
    {
        var (ok, err) = await Api.DeleteAdminCoursAsync(id);
        if (ok) await LoadCours();
        await ShowFeedback(ok, ok ? "Cours supprimé." : err ?? "Erreur");
    }

    // ── Actions — Niveaux ────────────────────────────────────────────────

    // Crée un nouveau niveau et recharge la liste
    private async Task CreateNiveau()
    {
        var (ok, err) = await Api.CreateAdminNiveauAsync(new { codeNiveau = newNivCode, nomNiveau = newNivNom });
        if (ok) { newNivCode = ""; newNivNom = ""; await LoadNiveaux(); }
        await ShowFeedback(ok, ok ? "Niveau ajouté." : err ?? "Erreur");
    }

    // Supprime un niveau par son identifiant et recharge la liste
    private async Task DeleteNiveau(int id)
    {
        var (ok, err) = await Api.DeleteAdminNiveauAsync(id);
        if (ok) await LoadNiveaux();
        await ShowFeedback(ok, ok ? "Niveau supprimé." : err ?? "Erreur");
    }

    // ── Actions — Cours-Niveau ───────────────────────────────────────────

    // Crée une liaison cours-niveau-professeur et recharge la liste
    private async Task CreateCoursNiveau()
    {
        var (ok, err) = await Api.CreateAdminCoursNiveauAsync(new { idCoursFk = newCnIdCours, idNiveauFk = newCnIdNiveau, idProfFk = newCnIdProf });
        if (ok) { newCnIdCours = 0; newCnIdNiveau = 0; newCnIdProf = 0; await LoadCoursNiveaux(); }
        await ShowFeedback(ok, ok ? "Liaison ajoutée." : err ?? "Erreur");
    }

    // Supprime une liaison cours-niveau et recharge la liste
    private async Task DeleteCoursNiveau(int id)
    {
        var (ok, err) = await Api.DeleteAdminCoursNiveauAsync(id);
        if (ok) await LoadCoursNiveaux();
        await ShowFeedback(ok, ok ? "Liaison supprimée." : err ?? "Erreur");
    }

    // ── Actions — Domaines ───────────────────────────────────────────────

    // Crée un nouveau domaine et recharge la liste
    private async Task CreateDomaine()
    {
        var (ok, err) = await Api.CreateAdminDomaineAsync(new { nom = newDomNom, idCoursNiveauFk = newDomIdCn });
        if (ok) { newDomNom = ""; newDomIdCn = 0; await LoadDomaines(); }
        await ShowFeedback(ok, ok ? "Domaine ajouté." : err ?? "Erreur");
    }

    // Supprime un domaine par son identifiant et recharge la liste
    private async Task DeleteDomaine(int id)
    {
        var (ok, err) = await Api.DeleteAdminDomaineAsync(id);
        if (ok) await LoadDomaines();
        await ShowFeedback(ok, ok ? "Domaine supprimé." : err ?? "Erreur");
    }

    // ── Actions — Sous-domaines ──────────────────────────────────────────

    // Crée un nouveau sous-domaine et recharge la liste
    private async Task CreateSousDomaine()
    {
        var (ok, err) = await Api.CreateAdminSousDomaineAsync(new { nomComp = newSdNom, idDomFk = newSdIdDom });
        if (ok) { newSdNom = ""; newSdIdDom = 0; await LoadSousDomaines(); }
        await ShowFeedback(ok, ok ? "Sous-domaine ajouté." : err ?? "Erreur");
    }

    // Supprime un sous-domaine par son identifiant et recharge la liste
    private async Task DeleteSousDomaine(int id)
    {
        var (ok, err) = await Api.DeleteAdminSousDomaineAsync(id);
        if (ok) await LoadSousDomaines();
        await ShowFeedback(ok, ok ? "Sous-domaine supprimé." : err ?? "Erreur");
    }

    // ── Actions — Compétences ────────────────────────────────────────────

    // Crée une nouvelle compétence et recharge la liste
    private async Task CreateCompetence()
    {
        var (ok, err) = await Api.CreateAdminCompetenceAsync(new { nom = newCompNom });
        if (ok) { newCompNom = ""; await LoadCompetences(); }
        await ShowFeedback(ok, ok ? "Compétence ajoutée." : err ?? "Erreur");
    }

    // Supprime une compétence par son identifiant et recharge la liste
    private async Task DeleteCompetence(int id)
    {
        var (ok, err) = await Api.DeleteAdminCompetenceAsync(id);
        if (ok) await LoadCompetences();
        await ShowFeedback(ok, ok ? "Compétence supprimée." : err ?? "Erreur");
    }

    // ── Actions — Aptitudes ──────────────────────────────────────────────

    // Crée une nouvelle aptitude et recharge la liste
    private async Task CreateAptitude()
    {
        var (ok, err) = await Api.CreateAdminAptitudeAsync(new { nom = newAptNom });
        if (ok) { newAptNom = ""; await LoadAptitudes(); }
        await ShowFeedback(ok, ok ? "Aptitude ajoutée." : err ?? "Erreur");
    }

    // Supprime une aptitude par son identifiant et recharge la liste
    private async Task DeleteAptitude(int id)
    {
        var (ok, err) = await Api.DeleteAdminAptitudeAsync(id);
        if (ok) await LoadAptitudes();
        await ShowFeedback(ok, ok ? "Aptitude supprimée." : err ?? "Erreur");
    }

    // ── Actions — Noms visées ────────────────────────────────────────────

    // Crée un nouveau nom de visée et recharge la liste
    private async Task CreateNomVisee()
    {
        var (ok, err) = await Api.CreateAdminNomViseeAsync(new { nom = newNvNom });
        if (ok) { newNvNom = ""; await LoadNomVisees(); }
        await ShowFeedback(ok, ok ? "Nom de visée ajouté." : err ?? "Erreur");
    }

    // Supprime un nom de visée par son identifiant et recharge la liste
    private async Task DeleteNomVisee(int id)
    {
        var (ok, err) = await Api.DeleteAdminNomViseeAsync(id);
        if (ok) await LoadNomVisees();
        await ShowFeedback(ok, ok ? "Nom de visée supprimé." : err ?? "Erreur");
    }

    // ── Actions — Visées à maîtriser ─────────────────────────────────────

    // Crée une nouvelle visée à maîtriser et recharge la liste
    private async Task CreateViseesMaitriser()
    {
        var (ok, err) = await Api.CreateAdminViseesMaitriserAsync(new { nom = newVmNom });
        if (ok) { newVmNom = ""; await LoadViseesMaitriser(); }
        await ShowFeedback(ok, ok ? "Visée à maîtriser ajoutée." : err ?? "Erreur");
    }

    // Supprime une visée à maîtriser par son identifiant et recharge la liste
    private async Task DeleteViseesMaitriser(int id)
    {
        var (ok, err) = await Api.DeleteAdminViseesMaitriserAsync(id);
        if (ok) await LoadViseesMaitriser();
        await ShowFeedback(ok, ok ? "Visée à maîtriser supprimée." : err ?? "Erreur");
    }
}
